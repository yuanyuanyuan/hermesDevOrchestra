    { tab: 0, codeLine: 0,
      flow: '<div><span class="role-pm font-bold">PM</span> 被唤醒 → 读取 AGENTS.md → 技术发现</div><div class="mt-2 text-gray-400 text-xs">按需深入：Cargo.toml → src/routes/users.rs:45-72 → src/middleware/mod.rs:8-15</div><div class="mt-1 text-emerald-400 text-xs">输出：8 项代码证据，具体到文件:行号</div>',
      context: '<div class="text-gray-300">PM profile 职责：需求澄清、技术研判、任务拆解</div><div class="mt-1 text-gray-500 text-xs">Toolsets: kanban, memory, clarify, file_read</div>',
      explain: 'Phase 1 第1步：自动技术发现。从入口出发，按需深入，输出含代码证据的技术发现报告' },
    { tab: 0, codeLine: 1,
      flow: '<div><span class="role-pm font-bold">PM</span> 执行一次一问逐步收缩澄清（Q1→Q11）</div><div class="mt-2 grid grid-cols-2 gap-2 text-xs text-gray-400"><div>Q1 核心目标 → "7天免登录"</div><div>Q2 用户群体 → "外部客户"</div><div>Q3 时间压力 → "1-2周"</div><div>Q4 登录方式 → "邮箱+密码"</div><div>Q5 处理方式 → "替换session"</div><div>Q6 过期交互 → "静默刷新"</div></div>',
      context: '<div class="text-amber-400">⭐ 推荐标签 + 大白话理由 + "其他"选项</div><div class="mt-1 text-gray-500 text-xs">若选"其他"→追加一轮细化；收敛上限防止无限澄清</div>',
      explain: 'Phase 1 第2步：动态顺序一次一问。每个问题带推荐标签和大白话理由，逐步收缩不确定性' },
    { tab: 0, codeLine: 2,
      flow: '<div><span class="role-pm font-bold">PM</span> 可行性检查 → 发现冲突 → 主动沟通</div><div class="mt-2 text-red-400 text-xs">冲突：范围(完整认证+密码重置) vs 时间(本周) = 不可行</div><div class="mt-1 text-emerald-400 text-xs">解决：Jacky 选择缩小范围 → 冲突消除</div>',
      context: '<div class="text-gray-300">持续可行性检查 + 冲突沟通 + 阻塞升级</div><div class="mt-1 text-gray-500 text-xs">所有判断必须有代码证据，任何角色可无歧义理解</div>',
      explain: 'Phase 1 第3步：可行性检查。需求 vs 代码现实的冲突必须主动沟通，不能沉默执行' },
    { tab: 0, codeLine: 3,
      flow: '<div><span class="role-pm font-bold">PM</span> 判断：涉及从未用过的 JWT 技术栈 → 需要 Research</div><div class="mt-2 text-xs text-gray-400">创建 T0.1: JWT 技术方案调研 → assignee: <span class="role-research font-bold">researcher</span></div>',
      context: '<div class="text-gray-300">Researcher profile：只分析不写代码</div><div class="mt-1 text-gray-500 text-xs">Toolsets: file_read, web, clarify, kanban, memory</div>',
      explain: 'Phase 1.5：技术研判（Research + POC）。技术不确定性高时，先调研产出方案文档，再 POC 验证' },
    { tab: 0, codeLine: 4,
      flow: '<div><span class="role-research font-bold">Researcher</span> 产出技术方案 → <span class="role-pm font-bold">PM</span> 判断需要 POC</div><div class="mt-2 text-xs text-gray-400">创建 T0.2: JWT RS256 POC 验证 → assignee: <span class="role-impl font-bold">implementer</span></div><div class="mt-1 text-cyan-400 text-xs">POC worktree: .worktrees/poc-jwt-rs256</div>',
      context: '<div class="text-gray-300">Implementer 在独立 worktree 中验证技术可行性</div><div class="mt-1 text-gray-500 text-xs">POC 成功 → 正式实现；POC 失败 → block + 换方案 / 升级用户 / 放弃</div>',
      explain: 'POC 在隔离 worktree 执行，不影响主分支。POC 失败的风险必须文档化并升级' },
    { tab: 0, codeLine: 5,
      flow: '<div><span class="role-pm font-bold">PM</span> 读取需求文档 + 技术方案 → 拆解为 4 个子任务</div><div class="mt-2 grid grid-cols-2 gap-2 text-xs"><div class="text-gray-300">T1 → <span class="role-impl font-bold">implementer</span>: 实现 JWT 模块</div><div class="text-gray-300">T2 → <span class="role-impl font-bold">implementer</span>: 编写测试</div><div class="text-gray-300">T3 → <span class="role-rev font-bold">reviewer</span>: 审查代码</div><div class="text-gray-300">T4 → <span class="role-impl font-bold">implementer</span>: 修复问题</div></div><div class="mt-1 text-gray-500 text-xs">依赖链: T1 → (T2 ∥ T3) → T4</div>',
      context: '<div class="text-gray-300">Orchestrator 接管：按状态机路由表派发任务</div><div class="mt-1 text-gray-500 text-xs">所有通信经由 Orchestrator 中转，支持审计追踪</div>',
      explain: 'Phase 2：任务拆解 + 派发。PM 拆解，Orchestrator 按状态机路由表自动派发' },
    { tab: 0, codeLine: 6,
      flow: '<div><span class="role-impl font-bold">Implementer</span> TDD 强制流程（RED→GREEN）</div><div class="mt-2 text-xs text-gray-400">1. 基线检查: cargo test --lib → 必须通过</div><div class="text-xs text-gray-400">2. 行为 A RED: test_valid_login → 失败</div><div class="text-xs text-gray-400">3. 行为 A GREEN: 最简实现 → 通过</div><div class="text-xs text-gray-400">4. 行为 B/C 同理...</div><div class="text-xs text-gray-400">5. 全量回归: 15/15 passed</div>',
      context: '<div class="text-gray-300">Implementer SOUL.md 规则：</div><div class="mt-1 text-xs text-gray-400">- 不做架构决策 → 必须 kanban_block</div><div class="text-xs text-gray-400">- 只执行编码，不做选型判断</div><div class="text-xs text-gray-400">- 每个行为必须有 RED→GREEN 证据</div>',
      explain: 'Phase 3：TDD 强制编码。从验收标准推导行为清单，每个行为执行严格的 RED→GREEN 循环' },
    { tab: 0, codeLine: 7,
      flow: '<div>T1 done → T2 / T3 并行 promoted to ready</div><div class="mt-2 text-xs"><span class="role-rev font-bold">Reviewer</span> 审查发现 1 个 high 严重级问题：</div><div class="mt-1 text-red-400 text-xs">src/auth/jwt.rs: token 过期时间硬编码，应可配置</div><div class="mt-1 text-amber-400 text-xs">approved: false → 进入 T4 修复流程</div>',
      context: '<div class="text-gray-300">Reviewer 硬门禁 + 严格只读</div><div class="mt-1 text-xs text-gray-400">- Toolsets 白名单：file_read, kanban_read, kanban_block...</div><div class="text-xs text-gray-400">- terminal 写操作被技术性拦截（dry-run）</div><div class="text-xs text-gray-400">- 审查不通过 → 代码无法进入下游</div>',
      explain: 'Phase 4：并行测试 + 审查。Reviewer 是硬门禁，审查不通过则阻断流程。Reviewer 只能报告问题，不能自行修复' },
    { tab: 0, codeLine: 8,
      flow: '<div><span class="role-impl font-bold">Implementer</span> 读取 Reviewer handoff → TDD 修复</div><div class="mt-2 text-xs text-gray-400">RED: test_token_expiry_is_configurable → 失败</div><div class="text-xs text-gray-400">GREEN: 改为环境变量配置 → 通过</div><div class="mt-2 text-emerald-400 text-xs">回归: 15/15 passed</div>',
      context: '<div class="text-gray-300">修复后自我进化：</div><div class="mt-1 text-xs text-cyan-400">memory add: "JWT token 过期时间应可配置"</div><div class="text-xs text-purple-400">skill_manage create: jwt-auth-checklist</div>',
      explain: 'Phase 5：修复 + 自我进化。经验自动沉淀为 memory 和 skill，进入三层架构的知识资产管理' },
    { tab: 0, codeLine: 9,
      flow: '<div><span class="role-devops font-bold">DevOps</span> 三层部署：dev/test → staging → production</div><div class="mt-2 grid grid-cols-3 gap-2 text-xs"><div class="text-emerald-400">✅ dev/test 自动部署</div><div class="text-amber-400">⏸ staging 需用户批准</div><div class="text-amber-400">⏸ production 需 UAT 通过后批准</div></div>',
      context: '<div class="text-gray-300">部署验证门控：</div><div class="mt-1 text-xs text-gray-400">dev/test → staging: 测试 + E2E + 性能基准</div><div class="text-xs text-gray-400">staging → production: 测试 + E2E（无性能）</div><div class="text-xs text-gray-400">production: 冒烟测试 + 自动 git tag</div>',
      explain: 'Phase 5.6：三层环境部署。dev/test 自动，staging/production 必须用户显式批准，每层有验证门控和自动回滚' },
    { tab: 0, codeLine: 10,
      flow: '<div class="text-emerald-400 text-lg font-bold">Project Alpha 全部任务完成 ✅</div><div class="mt-2 text-xs text-gray-300">变更: src/auth/jwt.rs, src/auth/routes.rs, config/default.toml</div><div class="text-xs text-gray-300">测试: 15/15 通过 | 经验: 2 条 memory, 1 个新 skill</div><div class="mt-2 text-xs text-gray-500">Jacky 审核决策 → 合并到 main → 最终反思</div>',
      context: '<div class="text-gray-300">Orchestrator 汇总完成 → Gateway 推送通知用户</div><div class="mt-1 text-gray-500 text-xs">用户确认后代码合并到 main，任务归档</div>',
      explain: 'Phase 6：完成通知 + 用户审核决策。Jacky 作为最终仲裁者，确认合并与发布' },

    // ===== Tab 1: 三级风险拦截 =====
    { tab: 1, codeLine: -1,
      flow: '<div class="text-gray-400">Risk Policy Engine 三层纵深拦截机制</div><div class="mt-2 grid grid-cols-3 gap-3 text-xs"><div class="bg-gray-900 border border-gray-700 rounded p-2"><div class="text-emerald-400 font-bold mb-1">L1 · Worker 自行决定</div><div class="text-gray-400">代码实现细节、变量命名</div><div class="text-gray-500 mt-1">直接执行 · 秒级</div></div><div class="bg-gray-900 border border-gray-700 rounded p-2"><div class="text-amber-400 font-bold mb-1">L2 · Reviewer 决策</div><div class="text-gray-400">技术方案、API 设计</div><div class="text-gray-500 mt-1">kanban_block → 秒~分钟</div></div><div class="bg-gray-900 border border-gray-700 rounded p-2"><div class="text-red-400 font-bold mb-1">L3 · 用户决策</div><div class="text-gray-400">安全凭证、破坏性重构、产品方向</div><div class="text-gray-500 mt-1">clarify() · 分钟~小时</div></div></div>',
      context: '<div class="text-gray-300">三层实现：</div><div class="mt-1 text-xs text-gray-400">1. Toolsets 白名单（主防线）</div><div class="text-xs text-gray-400">2. SOUL.md 软约束（LLM 级）</div><div class="text-xs text-gray-400">3. Plugin pre_tool_call 硬拦截（Plugin 级）</div>',
      explain: '声明式风险策略引擎：policies/risk.yaml 按 pattern 匹配将命令归入 L1/L2/L3' },
    { tab: 1, codeLine: 0,
      flow: '<div><span class="role-impl font-bold">Implementer</span> 执行 L1 操作：变量重命名</div><div class="mt-2 text-xs text-gray-400">pattern: "变量重命名" → level: L1</div><div class="mt-1 text-emerald-400 text-xs">→ 直接执行，无需审批</div>',
      context: '<div class="text-gray-300">L1 决策：Worker 自行决定</div><div class="mt-1 text-gray-500 text-xs">低影响、可回退的操作，由 Worker 根据 SOUL.md 规则直接判断</div>',
      explain: 'L1 场景：代码实现细节、变量命名、注释补充等低风险操作' },
    { tab: 1, codeLine: 1,
      flow: '<div><span class="role-impl font-bold">Implementer</span> 遇到技术选型：RS256 vs HS256?</div><div class="mt-2 text-xs text-gray-400">不在 task body 已明确，不在 risk policy 已规则化</div><div class="mt-1 text-amber-400 text-xs">→ kanban_block(reason="reviewer-needed: ...")</div>',
      context: '<div class="text-gray-300">L2 决策：Reviewer 审查</div><div class="mt-1 text-gray-500 text-xs">Dispatcher 检测到 "reviewer-needed:" 前缀 → 自动创建高优先级 Reviewer 子任务</div>',
      explain: 'L2 场景：技术方案、API 设计等需要专业判断但不涉及安全/破坏性变更的决策' },
    { tab: 1, codeLine: 2,
      flow: '<div><span class="role-impl font-bold">Implementer</span> 尝试执行：<span class="text-red-400 font-bold">git push --force</span></div><div class="mt-2 text-xs text-gray-400">Risk Policy: pattern "git push --force" → level: L3</div><div class="mt-1 bg-red-500/10 border border-red-500/30 rounded p-2 text-red-400 text-xs">❌ 命令被 Plugin pre_tool_call hook 硬拦截</div>',
      context: '<div class="text-gray-300">L3 硬拦截流程：</div><div class="mt-1 text-xs text-gray-400">1. Plugin 拦截 → kanban_block()</div><div class="text-xs text-gray-400">2. Gateway 推送决策请求给用户</div><div class="text-xs text-gray-400">3. 用户通过 CLI/Gateway 响应</div><div class="text-xs text-gray-400">4. Dispatcher unblock 恢复 Worker</div>',
      explain: 'L3 场景：安全凭证、破坏性重构、git push --force 等高风险操作，必须用户明确批准' },
    { tab: 1, codeLine: 3,
      flow: '<div><span class="role-rev font-bold">Reviewer</span> 尝试写操作：<span class="text-red-400 font-bold">rm test.txt</span></div><div class="mt-2 text-xs text-gray-400">Reviewer toolsets 白名单已禁用 file_write / terminal(写)</div><div class="mt-1 text-amber-400 text-xs">→ 白名单层拦截：toolset 未 enable，直接失败</div><div class="mt-1 text-red-400 text-xs">→ R8 兜底：若白名单放行，Read-Only Terminal Proxy 技术性拦截</div>',
      context: '<div class="text-gray-300">Reviewer 纵深防御体系：</div><div class="mt-1 text-xs text-gray-400">① Toolsets 白名单（主防线）</div><div class="text-xs text-gray-400">② SOUL.md "只读" prompt 约束（软约束）</div><div class="text-xs text-gray-400">③ R8 Terminal Proxy 技术性拦截（次防线）</div>',
      explain: 'Reviewer 严格只读：三层防御确保 reviewer 无法修改代码，只能报告问题' },
    { tab: 1, codeLine: 4,
      flow: '<div>审计日志记录</div><div class="mt-2 bg-gray-900 border border-gray-700 rounded p-2 text-xs font-mono"><div class="text-gray-500">[2026-05-10T14:32:01Z]</div><div class="text-red-400">L3_INTERCEPTED task=t_042 profile=implementer</div><div class="text-gray-400">  pattern="git push --force"</div><div class="text-gray-400">  command="git push --force origin main"</div><div class="text-amber-400">  action=kanban_block rule_id=R6-L3-003</div><div class="mt-1 text-emerald-400">[2026-05-10T14:35:22Z] USER_APPROVED by=jacky</div></div>',
      context: '<div class="text-gray-300">所有拦截事件写入审计日志</div><div class="mt-1 text-gray-500 text-xs">L3 项目永远不允许超时自动通过（R6 强制）</div>',
      explain: '审计追踪：Risk Policy Engine 记录完整的决策轨迹，支持事后溯源' },

    // ===== Tab 2: 架构总览 =====
    { tab: 2, codeLine: -1,
      flow: '<div class="grid grid-cols-4 gap-3 text-xs"><div class="bg-gray-900 border border-blue-500/30 rounded p-2 text-center"><div class="role-pm font-bold text-sm">PM</div><div class="text-gray-500 mt-1">需求澄清</div><div class="text-gray-500">任务拆解</div></div><div class="bg-gray-900 border border-purple-500/30 rounded p-2 text-center"><div class="role-orch font-bold text-sm">Orchestrator</div><div class="text-gray-500 mt-1">中枢路由</div><div class="text-gray-500">进度监控</div></div><div class="bg-gray-900 border border-cyan-500/30 rounded p-2 text-center"><div class="role-research font-bold text-sm">Researcher</div><div class="text-gray-500 mt-1">技术调研</div><div class="text-gray-500">方案文档</div></div><div class="bg-gray-900 border border-emerald-500/30 rounded p-2 text-center"><div class="role-impl font-bold text-sm">Implementer</div><div class="text-gray-500 mt-1">TDD 编码</div><div class="text-gray-500">POC 验证</div></div><div class="bg-gray-900 border border-amber-500/30 rounded p-2 text-center"><div class="role-rev font-bold text-sm">Reviewer</div><div class="text-gray-500 mt-1">只读审查</div><div class="text-gray-500">硬门禁</div></div><div class="bg-gray-900 border border-pink-500/30 rounded p-2 text-center"><div class="role-qa font-bold text-sm">QA-Tester</div><div class="text-gray-500 mt-1">功能验收</div><div class="text-gray-500">集成测试</div></div><div class="bg-gray-900 border border-orange-500/30 rounded p-2 text-center"><div class="role-devops font-bold text-sm">DevOps</div><div class="text-gray-500 mt-1">三层部署</div><div class="text-gray-500">验证门控</div></div><div class="bg-gray-900 border border-red-500/30 rounded p-2 text-center"><div class="role-sre font-bold text-sm">SRE-Observer</div><div class="text-gray-500 mt-1">根因分析</div><div class="text-gray-500">人工触发</div></div></div>',
      context: '<div class="text-gray-300">8 个标准角色（MVP 启用）</div><div class="mt-1 text-gray-500 text-xs">预留：pm-researcher, product-designer, growth-marketer（toolsets: []）</div>',
      explain: '角色是抽象的，实现可替换。Profile = config.yaml + SOUL.md + skills/ + .env' },
    { tab: 2, codeLine: 0,
      flow: '<div>Kanban 状态机</div><div class="mt-2 flex items-center gap-2 text-xs"><span class="text-gray-400">triage</span><span class="text-gray-600">→</span><span class="text-gray-400">todo</span><span class="text-gray-600">→</span><span class="text-emerald-400 font-bold">ready</span><span class="text-gray-600">→</span><span class="text-blue-400 font-bold">running</span><span class="text-gray-600">→</span><span class="text-amber-400 font-bold">blocked</span><span class="text-gray-600">→</span><span class="text-emerald-400 font-bold">done</span><span class="text-gray-600">→</span><span class="text-gray-500">archived</span></div><div class="mt-2 text-xs text-gray-400">Dispatcher 每 60s 循环：回收超时 claim → 回收崩溃 PID → promote parents → 原子 claim → spawn worker</div>',
      context: '<div class="text-gray-300">每个项目一个 Board，完全隔离</div><div class="mt-1 text-gray-500 text-xs">独立 SQLite · 独立 workspace · 独立 dispatcher · 任务不可跨 board 引用</div>',
      explain: 'Kanban 任务管理：状态机驱动任务生命周期，parents 依赖链自动管理任务就绪顺序' },
    { tab: 2, codeLine: 1,
      flow: '<div>背压感知任务准入（Backpressure）</div><div class="mt-2 text-xs text-gray-400">ratio = ready_implementer / max(ready_reviewer, 1)</div><div class="mt-2 grid grid-cols-3 gap-2 text-xs"><div class="bg-emerald-500/10 border border-emerald-500/30 rounded p-2"><div class="text-emerald-400 font-bold">ratio ≤ 2.0</div><div class="text-gray-400">正常派发</div></div><div class="bg-amber-500/10 border border-amber-500/30 rounded p-2"><div class="text-amber-400 font-bold">2.0 &lt; ratio ≤ 4.0</div><div class="text-gray-400">降低 spawn 频率</div></div><div class="bg-red-500/10 border border-red-500/30 rounded p-2"><div class="text-red-400 font-bold">ratio &gt; 4.0</div><div class="text-gray-400">暂停 implementer</div></div></div>',
      context: '<div class="text-gray-300">防止 implementer 压垮 reviewer</div><div class="mt-1 text-gray-500 text-xs">R17 死锁检测：下游 throughput=0 持续 30min → 升级告警</div>',
      explain: '背压机制：Dispatcher 感知队列深度比，自动调节 spawn 频率，防止积压无限膨胀' },
    { tab: 2, codeLine: 2,
      flow: '<div>自我进化三层架构</div><div class="mt-2 grid grid-cols-3 gap-2 text-xs"><div class="bg-gray-900 border border-gray-600 rounded p-2"><div class="text-gray-300 font-bold">锁定层</div><div class="text-gray-500 mt-1">Bundled skills</div><div class="text-gray-500">Hub-installed skills</div><div class="text-gray-500">Pinned skills</div><div class="mt-1 text-red-400">Curator 永不触碰</div></div><div class="bg-gray-900 border border-gray-600 rounded p-2"><div class="text-gray-300 font-bold">可变层</div><div class="text-gray-500 mt-1">Agent-created skills</div><div class="text-gray-500">MEMORY.md</div><div class="text-gray-500">Profile SOUL.md</div><div class="mt-1 text-emerald-400">Curator 定期审查</div></div><div class="bg-gray-900 border border-gray-600 rounded p-2"><div class="text-gray-300 font-bold">事实表</div><div class="text-gray-500 mt-1">Kanban task_runs</div><div class="text-gray-500">Session SQLite</div><div class="text-gray-500">.learnings/ 归档</div><div class="mt-1 text-blue-400">只增不改</div></div></div>',
      context: '<div class="text-gray-300">经验升级路径：</div><div class="mt-1 text-xs text-gray-400">correction → SOUL.md</div><div class="text-xs text-gray-400">insight → Skill</div><div class="text-xs text-gray-400">best_practice → SOUL.md</div><div class="text-xs text-gray-400">error_fix → Skill pitfall</div>',
      explain: '自我进化：以 Hermes 原生能力为主，经验自动沉淀，Curator 定期清理合并' },
    { tab: 2, codeLine: 3,
      flow: '<div>全链路可观测性：8 层故障定位</div><div class="mt-2 grid grid-cols-4 gap-2 text-xs"><div class="text-gray-400">1. 代码层</div><div class="text-gray-400">2. 审查层</div><div class="text-gray-400">3. 验收层</div><div class="text-gray-400">4. 环境层</div><div class="text-gray-400">5. 资源层</div><div class="text-gray-400">6. 部署层</div><div class="text-gray-400">7. 外部层</div><div class="text-gray-400">8. 策略层</div></div><div class="mt-2 text-xs text-cyan-400">Observability Plugin: post_tool_call + on_session_end hooks → observability_trace.db</div>',
      context: '<div class="text-gray-300">SRE-Observer：人工升级触发</div><div class="mt-1 text-gray-500 text-xs"> crash/timed_out 由 Hermes 官方自动回收 → ready 重派</div><div class="text-gray-500 text-xs">仅当人工判断需要深度分析时才创建 SRE 任务</div>',
      explain: '可观测性：零侵入采集工具调用链，8 层模型定位根因，SRE-Observer 输出结构化报告' },

    // ===== Tab 3: 配置与契约 =====
    { tab: 3, codeLine: -1,
      flow: '<div class="text-gray-400">Project-Level Profile Override 机制</div><div class="mt-2 bg-gray-900 border border-gray-700 rounded p-2 text-xs font-mono"><div class="text-gray-500"># project-alpha/.hermes/profiles/implementer.override.yaml</div><div class="text-gray-300">toolsets:</div><div class="text-gray-400">  enabled: [terminal, file, code_execution, memory, kanban, <span class="text-emerald-400">web</span>]</div><div class="text-gray-400">  disabled: [delegation]</div><div class="text-gray-300">model: <span class="text-cyan-400">codex</span></div></div><div class="mt-2 text-xs text-gray-400">合并语义：global base + project override（并集后按 project 优先）</div>',
      context: '<div class="text-gray-300">R3: 项目级 Profile 覆盖</div><div class="mt-1 text-xs text-gray-400">- 不污染全局 ~/.hermes/profiles/</div><div class="text-xs text-gray-400">- SOUL.md: extends global → 通用 → 项目 → 角色</div><div class="text-xs text-gray-400">- 防止一个项目的经验自动污染所有项目</div>',
      explain: 'Profile Override 是多项目隔离的核心：每个项目可对 toolsets / model / SOUL.md 做局部覆盖' },
    { tab: 3, codeLine: 0,
      flow: '<div class="text-gray-400">Memory 命名空间隔离（R7）</div><div class="mt-2 grid grid-cols-3 gap-2 text-xs"><div class="bg-gray-900 border border-gray-600 rounded p-2"><div class="text-blue-400 font-bold">.learnings/&lt;project&gt;/</div><div class="text-gray-500 mt-1">项目私有经验</div><div class="text-gray-500">默认写入位置</div><div class="mt-1 text-emerald-400">项目命名空间优先</div></div><div class="bg-gray-900 border border-gray-600 rounded p-2"><div class="text-purple-400 font-bold">.learnings/_global/</div><div class="text-gray-500 mt-1">经 Curator 审核</div><div class="text-gray-500">跨项目共享</div><div class="mt-1 text-amber-400">quality score ≥ 60</div></div><div class="bg-gray-900 border border-gray-600 rounded p-2"><div class="text-gray-400 font-bold">.learnings/_pending/</div><div class="text-gray-500 mt-1">待审核晋升请求</div><div class="text-gray-500">cross-project 标记</div><div class="mt-1 text-red-400">仅 Orchestrator/用户可标</div></div></div>',
      context: '<div class="text-gray-300">R7c: 冲突警告</div><div class="mt-1 text-xs text-red-400">若项目与全局 learning 相似但矛盾 → &lt;conflict_warning&gt;</div><div class="text-xs text-gray-400">Agent 不允许沉默选用项目版本</div>',
      explain: 'Memory 命名空间：默认私有、审核后共享，从根上阻断跨项目经验污染' },
    { tab: 3, codeLine: 1,
      flow: '<div class="text-gray-400">kanban_complete Handoff Metadata Schema（R13）</div><div class="mt-2 bg-gray-900 border border-gray-700 rounded p-2 text-xs font-mono"><div class="text-gray-300">{</div><div class="text-gray-400">  <span class="text-blue-400">behaviors</span>: [{name, test, status}, ...],</div><div class="text-gray-400">  <span class="text-blue-400">regression</span>: {run, passed, failed},</div><div class="text-gray-400">  <span class="text-blue-400">changed_files</span>: ["src/auth/jwt.rs"],</div><div class="text-gray-400">  <span class="text-blue-400">decisions</span>: ["RS256 over HS256"],</div><div class="text-gray-400">  <span class="text-blue-400">pitfalls</span>: ["token refresh needs sliding window"]</div><div class="text-gray-300">}</div></div>',
      context: '<div class="text-gray-300">R13: Schema 值安全校验</div><div class="mt-1 text-xs text-gray-400">decisions / pitfalls 等自由文本字段：</div><div class="text-xs text-red-400">- 禁止 shebang / bash heredoc</div><div class="text-xs text-red-400">- 禁止含 auth token 的 URL</div><div class="text-xs text-red-400">- 禁止 shell 命令注入元字符</div>',
      explain: 'Handoff Metadata：Implementer 完成时必须输出的结构化 TDD 证据，下游任务据此获得完整上下文' },
    { tab: 3, codeLine: 2,
      flow: '<div class="text-gray-400">Untrusted-Handoff 隔离（R16）</div><div class="mt-2 bg-gray-900 border border-gray-700 rounded p-2 text-xs font-mono"><div class="text-gray-500">&lt;!-- 下游 Worker 读取时自动包裹 --&gt;</div><div class="text-gray-300">&lt;<span class="text-red-400">untrusted-handoff</span> source="t_042"&gt;</div><div class="text-gray-400">  decisions: ["RS256 over HS256"]</div><div class="text-gray-400">  pitfalls: ["..."]</div><div class="text-gray-300">&lt;/<span class="text-red-400">untrusted-handoff</span>&gt;</div></div><div class="mt-2 text-xs text-amber-400">Worker Skill 必须声明：仅作为参考信息，不作为指令源</div>',
      context: '<div class="text-gray-300">R16: 不可信输入隔离</div><div class="mt-1 text-xs text-gray-400">禁止将 handoff metadata 直接拼接到指令性 prompt</div><div class="text-xs text-gray-400">防止上游通过 metadata 注入恶意指令</div>',
      explain: 'Untrusted-handoff 标签：将上游交付物标记为不可信输入，强制 Worker 仅参考、不执行' },
    { tab: 3, codeLine: 3,
      flow: '<div class="text-gray-400">必须 kanban_block 的触发条件清单（R14）</div><div class="mt-2 grid grid-cols-2 gap-2 text-xs"><div class="bg-gray-900 border border-gray-700 rounded p-2 text-gray-400">1. 架构决策 / 技术选型</div><div class="bg-gray-900 border border-gray-700 rounded p-2 text-gray-400">2. 被 Risk Policy 拦截（L3）</div><div class="bg-gray-900 border border-gray-700 rounded p-2 text-gray-400">3. 外部依赖不可用</div><div class="bg-gray-900 border border-gray-700 rounded p-2 text-gray-400">4. 关键测试失败（基线失败）</div><div class="bg-gray-900 border border-gray-700 rounded p-2 text-gray-400">5. 不在任务范围内的判断</div><div class="bg-gray-900 border border-gray-700 rounded p-2 text-gray-400">6. 超出 expected_duration_max</div></div>',
      context: '<div class="text-gray-300">R14: 禁止凭直觉决定何时 block</div><div class="mt-1 text-xs text-gray-400">Worker SOUL.md 必须显式列出清单</div><div class="text-xs text-gray-400">未列出的情况仍鼓励 block（安全侧）</div>',
      explain: 'Block 触发条件清单：将"凭直觉"转化为显式规则，防止 Worker 在不确定时沉默执行' },
    { tab: 3, codeLine: 4,
      flow: '<div class="text-gray-400">Worker 崩溃回滚与 Hibernation（R4 / §4.6-4.7）</div><div class="mt-2 grid grid-cols-2 gap-3 text-xs"><div class="bg-gray-900 border border-gray-700 rounded p-2"><div class="text-red-400 font-bold mb-1">Dirty-State Rollback</div><div class="text-gray-400">崩溃检测：PID 不存在 / 心跳超时</div><div class="text-gray-400 mt-1">1. 任务回退到 ready</div><div class="text-gray-400">2. git stash pop --index 恢复</div><div class="text-gray-400">3. rollback_count++</div><div class="text-gray-400">4. 重新派发 worker</div></div><div class="bg-gray-900 border border-gray-700 rounded p-2"><div class="text-blue-400 font-bold mb-1">Blocked Hibernation</div><div class="text-gray-400">Worker 调用 kanban_block() 后：</div><div class="text-gray-400 mt-1">1. Worker 进程退出</div><div class="text-gray-400">2. SQLite 写入 hibernation_snapshot</div><div class="text-gray-400">3. 释放 API context + 内存</div><div class="text-gray-400">4. unblock 后 --resume 恢复</div></div></div>',
      context: '<div class="text-gray-300">R12/R15: expected_duration_max</div><div class="mt-1 text-xs text-gray-400">Implementer 默认 60min / Reviewer 默认 10min</div><div class="text-xs text-gray-400">超时 → SIGTERM kill → 触发 R4 回滚</div>',
      explain: 'Worker 生命周期管理：崩溃时自动回滚到干净状态，block 时休眠释放资源，超时自动回收' },
    { tab: 3, codeLine: 5,
      flow: '<div class="text-gray-400">SRE-Observer 根因报告 Schema（R21）</div><div class="mt-2 bg-gray-900 border border-gray-700 rounded p-2 text-xs font-mono"><div class="text-gray-300">{</div><div class="text-gray-400">  <span class="text-blue-400">root_cause_category</span>: "environment|code|deployment|external|policy|review|qa",</div><div class="text-gray-400">  <span class="text-blue-400">confidence</span>: "high|medium|low",</div><div class="text-gray-400">  <span class="text-blue-400">symptom</span>: "pytest failed with ImportError",</div><div class="text-gray-400">  <span class="text-blue-400">root_cause</span>: "requirements.txt missing pyjwt",</div><div class="text-gray-400">  <span class="text-blue-400">responsible_profile</span>: "implementer",</div><div class="text-gray-400">  <span class="text-blue-400">upstream_fault</span>: null,</div><div class="text-gray-400">  <span class="text-blue-400">recommended_action</span>: "add pyjwt==2.8.0",</div><div class="text-gray-400">  <span class="text-blue-400">trace_anchor</span>: "tool_call_#7 terminal exited 1"</div><div class="text-gray-300">}</div></div>',
      context: '<div class="text-gray-300">R20/R23/R24: 故障升级触发条件</div><div class="mt-1 text-xs text-gray-400">- crashed / timed_out / rollback_count ≥ 2</div><div class="text-xs text-gray-400">- QA block 含 regression/critical_bug/security_flaw</div><div class="text-xs text-gray-400">- DevOps deploy 任务 outcome ≠ completed</div>',
      explain: 'SRE-Observer 输出结构化根因报告，9 个字段覆盖从症状到建议的完整链路' },
    { tab: 3, codeLine: 6,
      flow: '<div class="text-gray-400">技术疑问处理：路径 A vs 路径 B（§5.3-5.4）</div><div class="mt-2 grid grid-cols-2 gap-3 text-xs"><div class="bg-gray-900 border border-blue-500/30 rounded p-2"><div class="text-blue-400 font-bold mb-1">路径 A：主动 block（主流程）</div><div class="text-gray-400">Implementer 遵守 SOUL.md → 主动 kanban_block()</div><div class="text-gray-400 mt-1">Dispatcher 创建子任务 → Reviewer 决策 → unblock</div><div class="mt-1 text-emerald-400">优点：零额外基础设施，SQLite 持久化</div></div><div class="bg-gray-900 border border-purple-500/30 rounded p-2"><div class="text-purple-400 font-bold mb-1">路径 B：Defer 兜底</div><div class="text-gray-400">Claude 自动 AskUserQuestion → PreToolUse hook defer</div><div class="text-gray-400 mt-1">Worker 退出 → Dispatcher 读取 deferred_tool_use → --resume 恢复</div><div class="mt-1 text-emerald-400">优点：不依赖 prompt 遵守，原生机制</div></div></div>',
      context: '<div class="text-gray-300">决策路由优先级</div><div class="mt-1 text-xs text-gray-400">技术疑问 → Implementer block? → 路径 A</div><div class="text-xs text-gray-400">           → Claude AskUserQuestion? → 路径 B</div>',
      explain: '双路径技术疑问处理：主流程依赖 Worker 自觉遵守，兜底路径依赖 Claude defer 机制，两者互补' },
  ]
};

// ===== 流程模拟器：阶段定义 =====
const PHASES = [
  { name: '开始', actor: 'user', action: 'none', desc: 'Jacky 提交需求："每次重启浏览器都要重新登录"', detail: 'Project Alpha — Rust + Axum + PostgreSQL。点击"下一步"创建需求任务。' },
  { name: '需求提交', actor: 'pm', action: 'create', task: { id: 'T0', title: '改善登录体验 — 需求澄清', assignee: 'pm', status: 'triage', parents: [], body: '用户反馈每次重启浏览器都要重新登录' }, desc: '创建 T0，状态 triage', detail: 'PM profile 被唤醒，在 Kanban 中创建需求澄清任务。' },
  { name: 'PM 分析', actor: 'pm', action: 'spawn', taskId: 'T0', desc: 'T0: triage → running', detail: 'PM 执行技术发现（按需深入代码）+ 一次一问逐步澄清 + 可行性检查。' },
  { name: '需求完成', actor: 'pm', action: 'complete', taskId: 'T0', desc: 'T0: running → done', detail: 'PM 完成需求文档，包含 8 项代码证据和验收标准。' },
  { name: 'Research 任务', actor: 'pm', action: 'create', task: { id: 'T0.1', title: 'JWT 技术方案调研', assignee: 'researcher', status: 'todo', parents: ['T0'], body: '调研 JWT 签名方案、库选型、安全性考虑' }, desc: '创建 T0.1，依赖 T0', detail: 'PM 判断涉及从未用过的 JWT 技术栈，需要 Research。' },
  { name: 'Research 就绪', actor: 'orchestrator', action: 'promote', taskId: 'T0.1', desc: 'T0.1: todo → ready（T0 done）', detail: 'Dispatcher 检查 parents：T0 已 done → T0.1 自动提升为 ready。' },
  { name: 'Research 执行', actor: 'researcher', action: 'spawn_then_complete', taskId: 'T0.1', desc: 'T0.1: ready → running → done', detail: 'Researcher 产出技术方案：推荐 RS256 + jsonwebtoken 库。建议需要 POC。' },
  { name: 'POC 任务', actor: 'pm', action: 'create', task: { id: 'T0.2', title: 'JWT RS256 POC 验证', assignee: 'implementer', status: 'todo', parents: ['T0.1'], body: '在独立 worktree 中验证 RS256 签名性能和密钥轮换' }, desc: '创建 T0.2，依赖 T0.1', detail: 'PM 根据 Researcher 建议创建 POC 任务。' },
  { name: 'POC 就绪', actor: 'orchestrator', action: 'promote', taskId: 'T0.2', desc: 'T0.2: todo → ready（T0.1 done）', detail: 'Dispatcher 检查 parents：T0.1 已 done → T0.2 提升为 ready。' },
  { name: 'POC 执行', actor: 'implementer', action: 'spawn_then_complete', taskId: 'T0.2', desc: 'T0.2: ready → running → done', detail: 'Implementer 在 .worktrees/poc-jwt-rs256 执行 POC。RS256 签名 1000 次/秒，密钥轮换正常。' },
  { name: '任务拆解', actor: 'pm', action: 'create_multi', tasks: [
    { id: 'T1', title: '实现 JWT 认证模块', assignee: 'implementer', status: 'todo', parents: ['T0.2'], body: '实现登录/注册/刷新接口，使用 RS256' },
    { id: 'T2', title: '编写认证模块测试', assignee: 'implementer', status: 'todo', parents: ['T1'], body: '单元测试 + 集成测试，覆盖正常/异常流程' },
    { id: 'T3', title: '审查认证模块代码', assignee: 'reviewer', status: 'todo', parents: ['T1'], body: '检查安全性、代码规范、错误处理' },
    { id: 'T4', title: '修复审查发现的问题', assignee: 'implementer', status: 'todo', parents: ['T3'], body: '根据 reviewer findings 修复代码' },
    { id: 'T5', title: '部署发布到三层环境', assignee: 'devops-engineer', status: 'todo', parents: ['T2','T4'], body: 'dev/test → staging → production' }
  ], desc: 'PM 拆解为 5 个子任务', detail: '任务依赖链：T1 → (T2 ∥ T3) → T4；T2 + T4 → T5' },
  { name: 'T1 就绪', actor: 'orchestrator', action: 'promote', taskId: 'T1', desc: 'T1: todo → ready（T0.2 done）', detail: 'Dispatcher 检查 parents：T0.2 已 done → T1 提升为 ready。' },
  { name: 'T1 实现', actor: 'implementer', action: 'spawn_then_complete', taskId: 'T1', desc: 'T1: ready → running → done', detail: 'Implementer TDD 强制流程：RED→GREEN 循环，3 个行为各有测试，15/15 回归通过。' },
  { name: 'T2/T3 就绪', actor: 'orchestrator', action: 'promote_multi', taskIds: ['T2','T3'], desc: 'T2/T3: todo → ready（T1 done）', detail: 'T1 done 后，T2 和 T3 同时满足 parents 条件，并行提升为 ready。' },
  { name: 'T2 测试 + T3 审查', actor: 'multi', action: 'parallel', operations: [
    { taskId: 'T2', type: 'complete', desc: 'T2: ready → running → done' },
    { taskId: 'T3', type: 'block', desc: 'T3: ready → running → blocked', finding: 'token 过期时间硬编码，应可配置' }
  ], desc: 'T2 完成，T3 发现问题并 block', detail: '并行执行：T2 测试通过；Reviewer 发现 high 严重级问题，T3 blocked。' },
  { name: '修复任务就绪', actor: 'orchestrator', action: 'promote', taskId: 'T4', desc: 'T4: todo → ready（T3 done/blocked?）', detail: '注意：T3 是 blocked 不是 done，但 T4 的 parents 是 T3。在实际系统中 blocked 任务仍视为完成审查动作，T4 可进入 ready。此处简化为 T4 提升为 ready。' },
  { name: 'T4 修复', actor: 'implementer', action: 'spawn_then_complete', taskId: 'T4', desc: 'T4: ready → running → done', detail: 'Implementer 读取 T3 handoff（findings），TDD 修复：token 过期时间改为环境变量配置。' },
  { name: 'T5 就绪', actor: 'orchestrator', action: 'promote', taskId: 'T5', desc: 'T5: todo → ready（T2 + T4 done）', detail: 'Dispatcher 检查 parents：T2 done AND T4 done → T5 提升为 ready。' },
  { name: '三层部署', actor: 'devops-engineer', action: 'deploy', taskId: 'T5', stages: ['dev/test','staging','production'], desc: 'T5: ready → running → dev/test → staging → production → done', detail: 'DevOps 三层部署：dev/test 自动通过 → staging 需用户批准 → UAT 通过 → production 需再次批准 → 冒烟通过 → 自动 git tag。' },
  { name: '全部完成', actor: 'orchestrator', action: 'finish', desc: 'Project Alpha 全部任务完成 ✅', detail: '所有子任务 done → Gateway 推送通知 Jacky → 代码合并到 main → 2 条 memory + 1 个新 skill 沉淀。' }
];
</script>


<!-- ==================== VIEW ==================== -->
<div x-data="masterEngine(CONFIG, PHASES)" class="h-screen flex flex-col overflow-hidden">

  <!-- Header -->
  <header class="shrink-0 px-6 pt-4 pb-0 border-b border-gray-700">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl text-blue-400 font-bold mb-1" x-text="title"></h1>
        <p class="text-sm text-gray-500 mb-3" x-text="subtitle"></p>
      </div>
      <div class="text-xs text-gray-600 text-right">
        <div>Hermes v0.13.0</div>
        <div>Phase 19 Design</div>
      </div>
    </div>
    <div class="flex gap-0.5 border-b-2 border-gray-700">
      <template x-for="(tab, i) in tabs" :key="i">
        <button @click="switchTab(i)"
          class="px-4 py-2 border border-gray-700 border-b-0 rounded-t text-sm transition-colors"
          :class="activeTab === i
            ? 'text-blue-400 bg-gray-950 -mb-[2px] z-10 relative'
            : 'text-gray-500 hover:text-gray-200 bg-surface'"
          x-text="tab"></button>
      </template>
    </div>
  </header>

  <main class="flex-1 overflow-hidden min-h-0 relative">
    <!-- Tab 0-3: 逐步执行实验室 -->
    <template x-for="(tab, ti) in tabs.slice(0,4)" :key="ti">
      <div x-show="activeTab === ti" x-cloak
           x-transition:enter="transition-opacity duration-200"
           x-transition:enter-start="opacity-0"
           x-transition:enter-end="opacity-100"
           class="h-full flex flex-col absolute inset-0">
        <div class="shrink-0 px-6 py-3 flex gap-3 items-center">
          <button @click="prev()" class="px-3 py-2 bg-gray-800 border border-gray-700 rounded text-sm"
                  :disabled="current === 0" :class="current === 0 ? 'opacity-40' : ''">◀</button>
          <button @click="next()" class="px-4 py-2 bg-blue-500 text-gray-950 rounded text-sm font-semibold">下一步 ▶</button>
          <button @click="togglePlay()" class="px-4 py-2 rounded text-sm border"
                  :class="isPlaying ? 'bg-amber-500/20 border-amber-500 text-amber-400' : 'bg-gray-800 border-gray-700'"
                  x-text="isPlaying ? '⏸ 暂停' : '▶ 自动'"></button>
          <button @click="reset()" class="px-4 py-2 bg-red-500 text-white rounded text-sm">重置</button>
          <span class="text-sm text-gray-500" x-text="progress"></span>
          <span class="text-xs text-gray-500 ml-2">速度</span>
          <input type="range" min="200" max="2000" x-model="speed" class="w-24 accent-blue-500">
        </div>
        <div class="flex-1 grid grid-cols-[2fr_1fr] gap-4 px-6 pb-4 overflow-hidden min-h-0">
          <div class="bg-gray-900 border border-gray-700 rounded-lg overflow-hidden flex flex-col">
            <div class="shrink-0 px-4 py-2 border-b border-gray-700 text-sm text-gray-500 bg-white/5 flex justify-between">
              <span x-text="tabs[activeTab] + ' 视图'"></span>
              <span class="text-xs text-gray-600 uppercase tracking-wider" x-text="tabStepName"></span>
            </div>
            <div class="flex-1 p-4 overflow-y-auto min-h-0">
              <div class="text-sm leading-7" x-html="step?.flow ?? ''"></div>
            </div>
          </div>
          <div class="flex flex-col gap-4 overflow-hidden">
            <template x-for="(label, pi) in panelLabels" :key="pi">
              <div class="bg-gray-900 border border-gray-700 rounded-lg overflow-hidden flex flex-col flex-1 min-h-0">
                <div class="shrink-0 px-4 py-2 border-b border-gray-700 text-sm text-gray-500 bg-white/5"
                     x-text="label"></div>
                <div class="flex-1 p-4 overflow-y-auto min-h-0 text-sm" x-html="state(label.toLowerCase())"></div>
              </div>
            </template>
          </div>
        </div>
        <div class="shrink-0 px-6 py-3 border-t border-gray-700">
          <div class="border-l-4 border-purple-500 bg-purple-500/5 rounded-r px-4 py-2 text-sm"
               x-html="step?.explain ?? ''"></div>
        </div>
      </div>
    </template>

    <!-- Tab 4: 流程模拟器 -->
    <div x-show="activeTab === 4" x-cloak
         x-transition:enter="transition-opacity duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         class="h-full flex flex-col absolute inset-0">

      <!-- 模拟器控制栏 -->
      <div class="shrink-0 px-6 py-3 flex gap-3 items-center border-b border-gray-700 bg-gray-950">
        <button @click="simPrev()" class="px-3 py-2 bg-gray-800 border border-gray-700 rounded text-sm"
                :disabled="simPhase === 0" :class="simPhase === 0 ? 'opacity-40' : ''">◀ 上一步</button>
        <button @click="simNext()" class="px-4 py-2 bg-blue-500 text-gray-950 rounded text-sm font-semibold"
                :disabled="simPhase >= maxPhase">下一步 ▶</button>
        <button @click="simReset()" class="px-3 py-2 bg-red-500 text-white rounded text-sm">重置</button>
        <div class="ml-4 flex flex-col">
          <span class="text-xs text-gray-500" x-text="'Phase ' + simPhase + ' / ' + maxPhase"></span>
          <span class="text-sm font-bold text-blue-400" x-text="currentPhase?.name ?? ''"></span>
        </div>
        <div class="ml-auto flex gap-4 text-xs items-center">
          <div class="flex items-center gap-2">
            <span class="text-gray-500">背压:</span>
            <span class="font-bold" :class="bpClass()" x-text="bpRatio().toFixed(1)"></span>
            <span class="text-gray-600" x-text="bpLabel()"></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-gray-500">Ready:</span>
            <span class="text-emerald-400 font-bold" x-text="readyCount()"></span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-gray-500">Running:</span>
            <span class="text-blue-400 font-bold" x-text="runningCount()"></span>
          </div>
        </div>
      </div>

      <!-- 看板区域 -->
      <div class="flex-1 overflow-hidden min-h-0 flex flex-col">
        <div class="flex-1 overflow-x-auto overflow-y-hidden px-6 py-4">
          <div class="flex gap-3 h-full" style="min-width: 1400px;">
            <template x-for="col in columns" :key="col">
              <div class="flex-1 min-w-[180px] flex flex-col">
                <div class="shrink-0 px-3 py-2 rounded-t border-t-2 bg-gray-900 border border-gray-700"
                     :class="'col-' + col">
                  <div class="flex justify-between items-center">
                    <span class="text-xs font-bold uppercase tracking-wider" :class="colColor(col)" x-text="col"></span>
                    <span class="text-xs text-gray-600" x-text="tasksByStatus(col).length"></span>
                  </div>
                </div>
                <div class="flex-1 overflow-y-auto min-h-0 bg-gray-900/50 border-x border-b border-gray-700 rounded-b p-2 space-y-2">
                  <template x-for="task in tasksByStatus(col)" :key="task.id">
                    <div @click="selectTask(task.id)"
                         class="p-2 rounded border cursor-pointer transition-colors hover:bg-gray-800"
                         :class="selectedTask === task.id ? 'border-blue-500 bg-blue-500/10' : 'border-gray-700 bg-gray-900'">
                      <div class="flex justify-between items-start mb-1">
                        <span class="text-xs text-gray-500" x-text="task.id"></span>
                        <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-800" :class="roleColor(task.assignee)" x-text="task.assignee"></span>
                      </div>
                      <div class="text-xs text-gray-200 leading-relaxed mb-1" x-text="task.title"></div>
                      <div class="flex gap-1 flex-wrap" x-show="task.parents.length > 0">
                        <template x-for="p in task.parents" :key="p">
                          <span class="text-[10px] text-gray-500 bg-gray-800 px-1 rounded">← <span x-text="p"></span></span>
                        </template>
                      </div>
                      <div class="flex gap-1 mt-1" x-show="task.rollbackCount > 0">
                        <span class="text-[10px] text-red-400">↻ <span x-text="task.rollbackCount"></span></span>
                      </div>
                    </div>
                  </template>
                </div>
              </div>
            </template>
          </div>
        </div>

        <!-- 底部：Phase 说明 + 操作日志 -->
        <div class="shrink-0 px-6 py-3 border-t border-gray-700 bg-gray-950 grid grid-cols-[1fr_280px] gap-4">
          <!-- Phase 说明 -->
          <div>
            <div class="text-xs text-gray-500 mb-1" x-text="(currentPhase?.actor ? currentPhase.actor + ' · ' : '') + (currentPhase?.desc ?? '')"></div>
            <div class="text-sm text-gray-300" x-text="currentPhase?.detail ?? '点击"下一步"开始模拟整个工作流'"></div>
            <div x-show="selectedTaskObj" class="mt-2 p-2 bg-gray-900 border border-gray-700 rounded text-xs">
              <div class="flex gap-2 items-center mb-1">
                <span class="text-gray-500" x-text="selectedTaskObj.id"></span>
                <span class="font-bold" :class="roleColor(selectedTaskObj.assignee)" x-text="selectedTaskObj.assignee"></span>
                <span class="text-gray-400" x-text="selectedTaskObj.status"></span>
              </div>
              <div class="text-gray-400" x-text="selectedTaskObj.body"></div>
            </div>
          </div>
          <!-- 操作日志 -->
          <div class="bg-gray-900 border border-gray-700 rounded overflow-hidden flex flex-col h-32">
            <div class="shrink-0 px-3 py-1 border-b border-gray-700 text-xs text-gray-500 bg-white/5">操作日志</div>
            <div class="flex-1 overflow-y-auto p-2 space-y-1 text-[11px] font-mono">
              <template x-for="(log, i) in logs" :key="i">
                <div class="text-gray-400" x-html="log"></div>
              </template>
              <div x-show="logs.length === 0" class="text-gray-600">等待操作...</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>


<!-- ==================== ENGINE ==================== -->
<script>
function masterEngine(config, phases) {
  return {
    // === 共享 ===
    activeTab: 0,
    title: config.title,
    subtitle: config.subtitle || '',
    tabs: config.tabs || ['演示'],
    panelLabels: config.panelLabels || ['上下文'],

    // === Tab 0-3: 逐步执行 ===
    current: 0,
    isPlaying: false,
    speed: 800,
    timer: null,
    allSteps: config.steps || [],

    get tabSteps() {
      return this.allSteps.filter(s => s.tab === this.activeTab);
    },
    get maxStep() { return this.tabSteps.length - 1; },
    get step() {
      const s = this.tabSteps[Math.min(this.current, this.maxStep)];
      return s || {};
    },
    get progress() {
      const name = this.tabStepName;
      return name ? `${name} · Step ${this.current} / ${this.maxStep}` : `Step ${this.current} / ${this.maxStep}`;
    },
    get tabStepName() {
      const names = ['需求提交', '技术发现', '一次一问澄清', '可行性检查', 'Research 触发', 'POC 验证', '任务拆解', 'TDD 执行', '并行审查', '修复进化', '三层部署', '完成通知', 'L1 自行决定', 'L2 Reviewer', 'L3 硬拦截', 'Reviewer 纵深防御', '审计日志', '8 角色', 'Kanban 状态机', '背压机制', '自我进化', '可观测性', 'Profile Override', 'Memory 命名空间', 'Handoff Schema', 'Untrusted-Handoff', 'Block 触发条件', 'Worker 生命周期', 'SRE 报告 Schema', '路径 A/B 决策路由'];
      const globalIndex = this.allSteps.indexOf(this.step);
      return names[globalIndex] || '';
    },
    next() { if (this.current < this.maxStep) this.current++; },
    prev() { if (this.current > 0) this.current--; },
    reset() { this.current = 0; this.stop(); },
    play() {
      if (this.current >= this.maxStep) this.current = 0;
      this.isPlaying = true;
      const tick = () => {
        if (this.current < this.maxStep && this.isPlaying) {
          this.current++;
          this.timer = setTimeout(tick, 2200 - this.speed);
        } else { this.isPlaying = false; }
      };
      tick();
    },
    stop() { this.isPlaying = false; clearTimeout(this.timer); },
    togglePlay() { this.isPlaying ? this.stop() : this.play(); },
    state(name) { return this.step?.[name] ?? '<span class="text-gray-600">—</span>'; },

    switchTab(i) {
      this.activeTab = i;
      this.current = 0;
      this.stop();
    },

    // === Tab 4: 流程模拟器 ===
    columns: ['triage','todo','ready','running','blocked','done','archived'],
    tasks: [],
    logs: [],
    simPhase: 0,
    phases: phases,
    selectedTask: null,

    get maxPhase() { return this.phases.length - 1; },
    get currentPhase() { return this.phases[this.simPhase] || null; },
    get selectedTaskObj() {
      return this.tasks.find(t => t.id === this.selectedTask) || null;
    },

    tasksByStatus(status) {
      return this.tasks.filter(t => t.status === status);
    },

    selectTask(id) {
      this.selectedTask = this.selectedTask === id ? null : id;
    },

    roleColor(role) {
      const map = { pm: 'role-pm', orchestrator: 'role-orch', implementer: 'role-impl',
        reviewer: 'role-rev', 'qa-tester': 'role-qa', 'devops-engineer': 'role-devops',
        'sre-observer': 'role-sre', researcher: 'role-research' };
      return map[role] || 'text-gray-400';
    },

    colColor(col) {
      const map = { triage: 'text-gray-400', todo: 'text-gray-400', ready: 'text-emerald-400',
        running: 'text-blue-400', blocked: 'text-amber-400', done: 'text-emerald-400', archived: 'text-gray-500' };
      return map[col] || 'text-gray-400';
    },

    bpRatio() {
      const readyImpl = this.tasks.filter(t => t.status === 'ready' && t.assignee === 'implementer').length;
      const readyRev = this.tasks.filter(t => t.status === 'ready' && t.assignee === 'reviewer').length;
      return readyImpl / Math.max(readyRev, 1);
    },

    bpClass() {
      const r = this.bpRatio();
      if (r <= 2.0) return 'text-emerald-400';
      if (r <= 4.0) return 'text-amber-400';
      return 'text-red-400';
    },

    bpLabel() {
      const r = this.bpRatio();
      if (r <= 2.0) return '(正常)';
      if (r <= 4.0) return '(降速)';
      return '(暂停)';
    },

    readyCount() { return this.tasks.filter(t => t.status === 'ready').length; },
    runningCount() { return this.tasks.filter(t => t.status === 'running').length; },

    // 检查 task 的 parents 是否全部 done/archived
    parentsDone(task) {
      if (!task.parents || task.parents.length === 0) return true;
      return task.parents.every(pid => {
        const p = this.tasks.find(x => x.id === pid);
        return p && (p.status === 'done' || p.status === 'archived');
      });
    },

    // 提升所有 parents 已完成的 todo 任务
    autoPromote() {
      let promoted = [];
      this.tasks.forEach(t => {
        if (t.status === 'todo' && this.parentsDone(t)) {
          t.status = 'ready';
          promoted.push(t.id);
        }
      });
      return promoted;
    },

    log(msg) {
      this.logs.unshift(msg);
      if (this.logs.length > 20) this.logs.pop();
    },

    simReset() {
      this.tasks = [];
      this.logs = [];
      this.simPhase = 0;
      this.selectedTask = null;
    },

    simPrev() {
      if (this.simPhase <= 0) return;
      this.simPhase--;
      // 回退比较复杂，简单处理：重置到该 phase 的初始状态
      // 实际上回退需要撤销操作，这里简化为不允许回退到已执行的 phase
      // 或者重新从头模拟到上一步
      this.simReset();
      for (let i = 0; i < this.simPhase; i++) {
        this._applyPhase(i);
      }
    },

    simNext() {
      if (this.simPhase >= this.maxPhase) return;
      this._applyPhase(this.simPhase);
      this.simPhase++;
    },

    _applyPhase(idx) {
      const phase = this.phases[idx];
      if (!phase) return;
      const actor = phase.actor || 'system';
      const color = this._actorColor(actor);

      switch (phase.action) {
        case 'none':
          this.log(`<span class="${color}">[${actor}]</span> ${phase.desc}`);
          break;

        case 'create':
          if (phase.task) {
            this.tasks.push(JSON.parse(JSON.stringify(phase.task)));
            this.log(`<span class="${color}">[${actor}]</span> 创建 <span class="text-blue-400">${phase.task.id}</span> → ${phase.task.status}`);
          }
          break;

        case 'create_multi':
          if (phase.tasks) {
            phase.tasks.forEach(t => {
              this.tasks.push(JSON.parse(JSON.stringify(t)));
              this.log(`<span class="${color}">[${actor}]</span> 创建 <span class="text-blue-400">${t.id}</span> → ${t.status}`);
            });
          }
          break;

        case 'spawn': {
          const t = this.tasks.find(x => x.id === phase.taskId);
          if (t) {
            const old = t.status;
            t.status = 'running';
            this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> ${old} → running`);
          }
          break;
        }

        case 'complete': {
          const t = this.tasks.find(x => x.id === phase.taskId);
          if (t) {
            const old = t.status;
            t.status = 'done';
            this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> ${old} → done`);
            const promoted = this.autoPromote();
            if (promoted.length) {
              this.log(`<span class="text-purple-400">[orchestrator]</span> promote: ${promoted.join(', ')} → ready`);
            }
          }
          break;
        }

        case 'promote': {
          const t = this.tasks.find(x => x.id === phase.taskId);
          if (t && t.status === 'todo' && this.parentsDone(t)) {
            t.status = 'ready';
            this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> todo → ready`);
          }
          break;
        }

        case 'promote_multi': {
          const promoted = [];
          phase.taskIds.forEach(tid => {
            const t = this.tasks.find(x => x.id === tid);
            if (t && t.status === 'todo' && this.parentsDone(t)) {
              t.status = 'ready';
              promoted.push(t.id);
            }
          });
          if (promoted.length) {
            this.log(`<span class="${color}">[${actor}]</span> promote: ${promoted.join(', ')} → ready`);
          }
          break;
        }

        case 'spawn_then_complete': {
          const t = this.tasks.find(x => x.id === phase.taskId);
          if (t) {
            t.status = 'running';
            this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> → running`);
            t.status = 'done';
            this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> → done`);
            const promoted = this.autoPromote();
            if (promoted.length) {
              this.log(`<span class="text-purple-400">[orchestrator]</span> promote: ${promoted.join(', ')} → ready`);
            }
          }
          break;
        }

        case 'parallel': {
          phase.operations.forEach(op => {
            const t = this.tasks.find(x => x.id === op.taskId);
            if (!t) return;
            if (op.type === 'complete') {
              t.status = 'done';
              this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> → done`);
            } else if (op.type === 'block') {
              t.status = 'blocked';
              this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> → blocked (${op.finding || ''})`);
            }
          });
          const promoted = this.autoPromote();
          if (promoted.length) {
            this.log(`<span class="text-purple-400">[orchestrator]</span> promote: ${promoted.join(', ')} → ready`);
          }
          break;
        }

        case 'deploy': {
          const t = this.tasks.find(x => x.id === phase.taskId);
          if (t) {
            t.status = 'running';
            this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> → running`);
            if (phase.stages) {
              phase.stages.forEach((stage, i) => {
                const auto = i === 0 ? '（自动）' : '（用户批准）';
                this.log(`<span class="${color}">[${actor}]</span> 部署到 <span class="text-emerald-400">${stage}</span> ${auto}`);
              });
            }
            t.status = 'done';
            this.log(`<span class="${color}">[${actor}]</span> <span class="text-blue-400">${t.id}</span> → done · 自动 git tag`);
            const promoted = this.autoPromote();
            if (promoted.length) {
              this.log(`<span class="text-purple-400">[orchestrator]</span> promote: ${promoted.join(', ')} → ready`);
            }
          }
          break;
        }

        case 'finish':
          this.log(`<span class="text-emerald-400 font-bold">[${actor}]</span> ${phase.desc}`);
          break;
      }
    },

    _actorColor(actor) {
      const map = { pm: 'role-pm', orchestrator: 'role-orch', implementer: 'role-impl',
        reviewer: 'role-rev', researcher: 'role-research', 'devops-engineer': 'role-devops',
        'qa-tester': 'role-qa', user: 'text-gray-300', system: 'text-gray-400' };
      return map[actor] || 'text-gray-400';
    }
  };
}
</script>

</body>
</html>
