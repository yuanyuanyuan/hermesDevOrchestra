#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PACKAGE_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
ORCHESTRA_HOME="${ORCHESTRA_HOME:-$HOME/.hermes-orchestra}"

if [ -f "$ORCHESTRA_HOME/lib/orch-common.sh" ]; then
    # shellcheck source=/dev/null
    source "$ORCHESTRA_HOME/lib/orch-common.sh"
else
    # shellcheck source=/dev/null
    source "$SCRIPT_DIR/../lib/orch-common.sh"
fi

if [ "$#" -ne 2 ]; then
    echo "Usage: orch-init <project-id> <project-dir>" >&2
    exit 1
fi

PROJECT_ID="$1"
PROJECT_DIR_INPUT="$2"

orch_validate_project_id "$PROJECT_ID"
orch_require_command git
orch_require_command python3

if [ ! -d "$PROJECT_DIR_INPUT" ]; then
    echo "Project directory not found: $PROJECT_DIR_INPUT" >&2
    exit 1
fi

PROJECT_DIR="$(cd "$PROJECT_DIR_INPUT" && pwd)"

if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Project directory must already be a Git repository: $PROJECT_DIR" >&2
    exit 1
fi

orch_project_dirs "$PROJECT_ID"
WORKSPACE_ROOT="$(orch_project_workspace_root "$PROJECT_DIR" "$PROJECT_ID")"
OVERRIDE_DIR="$(orch_project_override_dir "$PROJECT_DIR")"
BOARD_SLUG="$(orch_project_board_slug "$PROJECT_ID")"
MEMORY_NAMESPACE="$(orch_project_memory_namespace "$PROJECT_ID")"

mkdir -p "$RUNTIME_DIR" "$STATE_DIR" "$AUDIT_DIR/archive" "$AUDIT_DIR/pending" "$CACHE_DIR" "$WORKSPACE_ROOT" "$OVERRIDE_DIR"

SETTINGS_SRC="$ORCHESTRA_HOME/claude-config-template/.claude/settings.json"
if [ ! -f "$SETTINGS_SRC" ]; then
    SETTINGS_SRC="$PACKAGE_DIR/claude-config/settings.json"
fi
if [ ! -f "$PROJECT_DIR/.claude/settings.json" ]; then
    if [ ! -f "$SETTINGS_SRC" ]; then
        echo "Claude settings template missing: $SETTINGS_SRC" >&2
        exit 1
    fi
    mkdir -p "$PROJECT_DIR/.claude"
    cp "$SETTINGS_SRC" "$PROJECT_DIR/.claude/settings.json"
    echo "Claude settings copied: $PROJECT_DIR/.claude/settings.json"
else
    echo "Claude settings already exist: $PROJECT_DIR/.claude/settings.json"
fi

{
    printf 'PROJECT_ID=%q\n' "$PROJECT_ID"
    printf 'PROJECT_DIR=%q\n' "$PROJECT_DIR"
    printf 'RUNTIME_DIR=%q\n' "$RUNTIME_DIR"
    printf 'STATE_DIR=%q\n' "$STATE_DIR"
    printf 'AUDIT_DIR=%q\n' "$AUDIT_DIR"
    printf 'CACHE_DIR=%q\n' "$CACHE_DIR"
    printf 'CLAUDE_SESSION=%q\n' "$CLAUDE_SESSION"
    printf 'CODEX_SESSION=%q\n' "$CODEX_SESSION"
    printf 'WORKSPACE_ROOT=%q\n' "$WORKSPACE_ROOT"
    printf 'OVERRIDE_DIR=%q\n' "$OVERRIDE_DIR"
    printf 'BOARD_SLUG=%q\n' "$BOARD_SLUG"
    printf 'MEMORY_NAMESPACE=%q\n' "$MEMORY_NAMESPACE"
} > "$STATE_DIR/project.env"

python3 - "$STATE_DIR/paths.json" "$PROJECT_ID" "$PROJECT_DIR" "$RUNTIME_DIR" "$STATE_DIR" "$AUDIT_DIR" "$CACHE_DIR" "$WORKSPACE_ROOT" "$OVERRIDE_DIR" "$BOARD_SLUG" "$MEMORY_NAMESPACE" <<'PY'
import json, sys
path, project_id, project_dir, runtime_dir, state_dir, audit_dir, cache_dir, workspace_root, override_dir, board_slug, memory_namespace = sys.argv[1:]
with open(path, "w", encoding="utf-8") as handle:
    json.dump({
        "project_id": project_id,
        "project_dir": project_dir,
        "runtime_dir": runtime_dir,
        "state_dir": state_dir,
        "audit_dir": audit_dir,
        "cache_dir": cache_dir,
        "workspace_root": workspace_root,
        "override_dir": override_dir,
        "board_slug": board_slug,
        "memory_namespace": memory_namespace,
    }, handle, indent=2)
    handle.write("\n")
PY

mkdir -p "$STATE_ROOT"
python3 - "$STATE_ROOT/projects.json" "$PROJECT_ID" "$PROJECT_DIR" "$RUNTIME_DIR" "$STATE_DIR" "$AUDIT_DIR" "$CACHE_DIR" "$WORKSPACE_ROOT" "$OVERRIDE_DIR" "$BOARD_SLUG" "$MEMORY_NAMESPACE" "$(orch_now)" <<'PY'
import json, os, sys
path, project_id, project_dir, runtime_dir, state_dir, audit_dir, cache_dir, workspace_root, override_dir, board_slug, memory_namespace, updated_at = sys.argv[1:]
try:
    with open(path, encoding="utf-8") as handle:
        projects = json.load(handle)
    if not isinstance(projects, list):
        projects = []
except Exception:
    projects = []

entry = {
    "project_id": project_id,
    "project_dir": project_dir,
    "runtime_dir": runtime_dir,
    "state_dir": state_dir,
    "audit_dir": audit_dir,
    "cache_dir": cache_dir,
    "workspace_root": workspace_root,
    "override_dir": override_dir,
    "board_slug": board_slug,
    "memory_namespace": memory_namespace,
    "updated_at": updated_at,
}
projects = [project for project in projects if project.get("project_id") != project_id]
projects.append(entry)
projects.sort(key=lambda project: project["project_id"])

tmp = f"{path}.tmp"
with open(tmp, "w", encoding="utf-8") as handle:
    json.dump(projects, handle, indent=2)
    handle.write("\n")
os.replace(tmp, path)
PY

python3 - "$STATE_DIR/current-task.json" "$PROJECT_ID" <<'PY'
import json, sys
path, project_id = sys.argv[1:]
with open(path, "w", encoding="utf-8") as handle:
    json.dump({"project_id": project_id, "state": "idle", "task_id": None}, handle, indent=2)
    handle.write("\n")
PY

SYNC_HELPER="$ORCHESTRA_HOME/bin/orch-profile-sync"
if [ ! -x "$SYNC_HELPER" ]; then
    SYNC_HELPER="$SCRIPT_DIR/orch-profile-sync"
fi
if [ -x "$SYNC_HELPER" ]; then
    "$SYNC_HELPER" "$PROJECT_ID" "$PROJECT_DIR" >/dev/null
fi

orch_append_audit "project_init" "$PROJECT_ID" "L1" "RECORDED" "" "Project initialized at $PROJECT_DIR" "" "" "" "" "orch-init" ""

echo "Project initialized: $PROJECT_ID"
echo "Runtime: $RUNTIME_DIR"
echo "State:   $STATE_DIR"
echo "Audit:   $AUDIT_DIR"
echo "Cache:   $CACHE_DIR"
echo "Workspace: $WORKSPACE_ROOT"
echo "Overrides: $OVERRIDE_DIR"
echo "Board: $BOARD_SLUG"
echo "Memory: $MEMORY_NAMESPACE"
