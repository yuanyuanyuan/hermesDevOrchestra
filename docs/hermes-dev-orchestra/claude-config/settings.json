{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "CLAUDE_CODE_CONTEXT_LENGTH": "200000"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "type": "command",
        "command": [
          "bash",
          "-c",
          "project=\"${HERMES_ORCHESTRA_PROJECT:-$(basename \"$PWD\")}\"; mkdir -p \"/tmp/hermes-orchestra/$project\"; event=\"$(printf '{\"event\":\"PermissionRequest\",\"ts\":\"%s\",\"session\":\"%s\",\"project\":\"%s\"}' \"$(date -Iseconds)\" \"${CLAUDE_SESSION_NAME:-unknown}\" \"$project\")\"; printf '%s\n' \"$event\" | tee -a \"/tmp/hermes-orchestra/$project/claude-events.jsonl\" \"/tmp/hermes-orchestra/claude-events.jsonl\" >/dev/null; exit 0"
        ],
        "matchers": ["Bash", "Edit", "Write"],
        "async": true,
        "timeout": 5000
      }
    ],
    "Notification": [
      {
        "type": "command",
        "command": [
          "bash",
          "-c",
          "project=\"${HERMES_ORCHESTRA_PROJECT:-$(basename \"$PWD\")}\"; mkdir -p \"/tmp/hermes-orchestra/$project\"; event=\"$(printf '{\"event\":\"Notification\",\"ts\":\"%s\",\"session\":\"%s\",\"project\":\"%s\"}' \"$(date -Iseconds)\" \"${CLAUDE_SESSION_NAME:-unknown}\" \"$project\")\"; printf '%s\n' \"$event\" | tee -a \"/tmp/hermes-orchestra/$project/claude-events.jsonl\" \"/tmp/hermes-orchestra/claude-events.jsonl\" >/dev/null"
        ],
        "async": true,
        "timeout": 3000
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": [
          "bash",
          "-c",
          "project=\"${HERMES_ORCHESTRA_PROJECT:-$(basename \"$PWD\")}\"; mkdir -p \"/tmp/hermes-orchestra/$project\"; event=\"$(printf '{\"event\":\"SessionStart\",\"ts\":\"%s\",\"session\":\"%s\",\"project\":\"%s\"}' \"$(date -Iseconds)\" \"${CLAUDE_SESSION_NAME:-unknown}\" \"$project\")\"; printf '%s\n' \"$event\" | tee -a \"/tmp/hermes-orchestra/$project/claude-events.jsonl\" \"/tmp/hermes-orchestra/claude-events.jsonl\" >/dev/null"
        ],
        "async": true,
        "timeout": 3000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": [
          "bash",
          "-c",
          "project=\"${HERMES_ORCHESTRA_PROJECT:-$(basename \"$PWD\")}\"; mkdir -p \"/tmp/hermes-orchestra/$project\"; event=\"$(printf '{\"event\":\"Stop\",\"ts\":\"%s\",\"session\":\"%s\",\"project\":\"%s\"}' \"$(date -Iseconds)\" \"${CLAUDE_SESSION_NAME:-unknown}\" \"$project\")\"; printf '%s\n' \"$event\" | tee -a \"/tmp/hermes-orchestra/$project/claude-events.jsonl\" \"/tmp/hermes-orchestra/claude-events.jsonl\" >/dev/null"
        ],
        "async": true,
        "timeout": 3000
      }
    ]
  },
  "permissionMode": "autoEdit",
  "allowedTools": ["Bash", "Edit", "Read", "Write", "Glob", "Grep", "Task"],
  "memory": {
    "enabled": true,
    "maxItems": 50
  },
  "subagents": {
    "enabled": true,
    "maxConcurrent": 3
  }
}
