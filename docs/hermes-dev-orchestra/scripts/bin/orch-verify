#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ORCHESTRA_HOME="${ORCHESTRA_HOME:-$HOME/.hermes-orchestra}"

echo "Hermes Dev Orchestra smoke verification"

if [ -x "$ORCHESTRA_HOME/tests/run-all.sh" ]; then
    exec "$ORCHESTRA_HOME/tests/run-all.sh"
fi

PACKAGE_RUNNER="$(cd "$SCRIPT_DIR/.." && pwd)/tests/run-all.sh"
if [ -x "$PACKAGE_RUNNER" ]; then
    exec "$PACKAGE_RUNNER"
fi

echo "Smoke test runner not found. Expected ORCHESTRA_HOME/tests/run-all.sh or package scripts/tests/run-all.sh." >&2
exit 1
