#!/bin/bash
# =============================================================================
# Compound Engineering Git Hooks - Installer
# =============================================================================
# Installs (or uninstalls) compound-aware git hooks into this repository.
#
# Usage:
#   scripts/bin/install-compound-hooks          # Install hooks
#   scripts/bin/install-compound-hooks --uninstall  # Remove compound hooks
#   COMPOUND_AUTO_RUN=true scripts/bin/install-compound-hooks  # Install with auto-run
# =============================================================================

set -eu

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
HOOKS_SOURCE="${REPO_ROOT}/scripts/git-hooks"
GIT_HOOKS_DIR="${REPO_ROOT}/.git/hooks"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ---- Helpers ----

log_info() {
    printf "%b%b%b\n" "$BLUE" "$1" "$RESET"
}

log_success() {
    printf "%b%b%b\n" "$GREEN" "$1" "$RESET"
}

log_warn() {
    printf "%b%b%b\n" "$YELLOW" "$1" "$RESET"
}

log_error() {
    printf "%b%b%b\n" "$RED" "$1" "$RESET"
}

# ---- Argument Parsing ----

UNINSTALL=false
if [ "${1:-}" = "--uninstall" ] || [ "${1:-}" = "-u" ]; then
    UNINSTALL=true
fi

# ---- Pre-flight Checks ----

if [ ! -d "$GIT_HOOKS_DIR" ]; then
    log_error "错误：找不到 .git/hooks 目录。请在 git 仓库根目录运行此脚本。"
    exit 1
fi

if [ ! -d "$HOOKS_SOURCE" ]; then
    log_error "错误：找不到 hooks 源目录：$HOOKS_SOURCE"
    exit 1
fi

# ---- Install ----

install_hook() {
    local hook_name="$1"
    local source_file="${HOOKS_SOURCE}/${hook_name}"
    local target_file="${GIT_HOOKS_DIR}/${hook_name}"
    local backup_file="${GIT_HOOKS_DIR}/${hook_name}.backup"

    if [ ! -f "$source_file" ]; then
        log_warn "跳过：源文件不存在 $hook_name"
        return
    fi

    # Check if target already exists and is NOT our hook
    if [ -f "$target_file" ]; then
        # Check if it's already our hook (by marker)
        if grep -q "Compound Engineering" "$target_file" 2>/dev/null; then
            log_info "  更新: $hook_name"
            cp "$source_file" "$target_file"
            chmod +x "$target_file"
            return
        fi

        # It's a different hook — back it up
        log_warn "  注意: $hook_name 已存在，备份到 ${hook_name}.backup"
        cp "$target_file" "$backup_file"
    fi

    cp "$source_file" "$target_file"
    chmod +x "$target_file"
    log_success "  安装: $hook_name"
}

# ---- Uninstall ----

uninstall_hook() {
    local hook_name="$1"
    local target_file="${GIT_HOOKS_DIR}/${hook_name}"
    local backup_file="${GIT_HOOKS_DIR}/${hook_name}.backup"

    if [ ! -f "$target_file" ]; then
        log_info "  跳过: $hook_name 未安装"
        return
    fi

    # Only remove if it's our hook
    if grep -q "Compound Engineering" "$target_file" 2>/dev/null; then
        rm "$target_file"
        log_success "  移除: $hook_name"

        # Restore backup if exists
        if [ -f "$backup_file" ]; then
            mv "$backup_file" "$target_file"
            log_info "  恢复: $hook_name (从备份)"
        fi
    else
        log_warn "  跳过: $hook_name 不是 compound 管理的 hook"
    fi
}

# ---- Main ----

echo ""
if [ "$UNINSTALL" = true ]; then
    printf "%b%b Compound Engineering Git Hooks - 卸载 %b\n" "$BOLD" "$YELLOW" "$RESET"
    echo ""

    uninstall_hook "post-commit"
    uninstall_hook "post-merge"
    uninstall_hook "prepare-commit-msg"

    echo ""
    log_success "卸载完成。"
else
    printf "%b%b Compound Engineering Git Hooks - 安装 %b\n" "$BOLD" "$CYAN" "$RESET"
    echo ""

    log_info "源目录: $HOOKS_SOURCE"
    log_info "目标目录: $GIT_HOOKS_DIR"
    echo ""

    install_hook "post-commit"
    install_hook "post-merge"
    install_hook "prepare-commit-msg"

    echo ""
    log_success "安装完成！"
    echo ""

    # Configuration hints
    printf "%b配置选项（可选）：%b\n" "$BOLD" "$RESET"
    echo ""
    echo "  1. 全自动模式（提交后自动调用 AI 记录文档）："
    echo "     export COMPOUND_AUTO_RUN=true"
    echo "     # 添加到 ~/.bashrc 或 ~/.zshrc 使其持久化"
    echo ""
    echo "  2. 静默模式（只记录日志，不输出到终端）："
    echo "     export COMPOUND_QUIET=true"
    echo ""
    echo "  3. 跳过某个提交的 compound 提醒："
    echo "     git commit -m 'fix: something [skip compound]'"
    echo ""

    # Check if codex is available
    if command -v codex >/dev/null 2>&1; then
        log_success "✓ Codex CLI 已安装"
    else
        log_warn "⚠ Codex CLI 未找到。如需自动运行，请先安装：npm install -g @openai/codex"
    fi

    # Check docs/solutions
    if [ -d "${REPO_ROOT}/docs/solutions" ]; then
        local count
        count="$(find "${REPO_ROOT}/docs/solutions" -name "*.md" -not -name "README.md" 2>/dev/null | wc -l)"
        log_info "✓ docs/solutions/ 已存在 (${count} 篇文档)"
    else
        log_info "ℹ docs/solutions/ 尚未创建，第一次运行 /ce-compound 时会自动建立"
    fi
fi

echo ""
