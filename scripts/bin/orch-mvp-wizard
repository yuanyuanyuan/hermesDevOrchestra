)
if codex_result["exit_code"] != 0:
    raise SystemExit(f"Codex real-worker demo failed: {codex_result}")
if not low_risk_path.is_file():
    raise SystemExit(f"Codex did not create expected low-risk file: {low_risk_path}")
low_risk_content = low_risk_path.read_text(encoding="utf-8")
if f"real_worker_demo_id: {demo_id}" not in low_risk_content or "codex_cli: completed" not in low_risk_content:
    raise SystemExit(f"Codex low-risk file content did not include required evidence: {low_risk_path}")

status_result = subprocess.run(
    ["git", "status", "--short", "--", low_risk_file.as_posix()],
    cwd=project_path,
    check=False,
    text=True,
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
)
diff_result = subprocess.run(
