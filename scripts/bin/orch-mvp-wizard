    raise SystemExit("Claude review produced no stdout evidence")

test_execution_ref = f"state://runs/{run_id}/test_execution_report.json"


def worker_payload(task, *, role, backend, idempotency_key, changed_files, diff_summary, commands, local_evidence):
    return {
        "idempotency_key": idempotency_key,
        "task_id": task["task_id"],
        "worker_response": {
            "protocol": "hermes-role-engine/v1",
            "role": role,
            "correlation_id": task["task_id"],
            "turn": 1,
            "status": "completed",
            "next_action": "complete",
            "role_specific_payload": {
                "requested_transition": "task_complete",
                "artifact_refs": [f"state://runs/{run_id}/run.json"],
                "changed_files": changed_files,
                "diff_summary": diff_summary,
                "write_scope_result": {
                    "within_scope": True,
                    "violations": [],
                    "forbidden_paths_touched": [],
                },
                "test_evidence_refs": [test_execution_ref] if changed_files else [],
                "risk_notes": [],
                "approval_refs": [],
                "commands": commands,
                "backend_execution": {
                    "backend": backend,
                    "backend_kind": "cli",
                    "executed": True,
                    "local_evidence": local_evidence,
                },
            },
            "conversation_context": [{"summary": "real-worker demo evidence was produced by local authenticated CLI workers"}],
        },
    }


