    action="submit_global_evaluation",
    what_happened="Wizard submitted global evaluation evidence that includes real Codex and Claude worker-output refs.",
    artifact_refs=[test_execution_ref, codex_worker_response["worker_output_report_ref"], claude_worker_response["worker_output_report_ref"]],
)
decision = post(
    f"/orchestra/decisions/{global_response['decision_id']}",
    {
        "idempotency_key": f"real-worker-final-acceptance-{demo_id}",
        "action": "approve",
        "actor": "kimi",
        "rationale": "Real worker demo evidence accepted with template debate fallback warning",
        "accepted_warning_refs": [global_response["global_evaluation_report_ref"]],
    },
    participant="wizard-as-kimi",
    stage="final_acceptance",
    action="approve_final_acceptance",
    what_happened="Wizard approved the explicit warning gate after real CLI worker evidence was recorded.",
    artifact_refs=[global_response["global_evaluation_report_ref"]],
)
final_acceptance_ref = decision["final_acceptance_ref"]
closeout_ref = f"state://runs/{run_id}/iteration_closeout_report.json"
proposals_ref = f"state://runs/{run_id}/system_improvement_proposals.json"
closeout = {
    "schema_version": "orchestra.v1",
    "artifact_type": "iteration_closeout_report",
    "run_id": run_id,
    "global_evaluation_report_ref": global_response["global_evaluation_report_ref"],
    "closeout_kind": "completed",
    "final_acceptance": {
        "accepted_by": "wizard",
        "authority": "kimi",
        "verdict": "accepted_with_warnings",
        "rationale": "Real Codex/Claude CLI worker demo completed with accepted template fallback warning",
        "decision_ref": final_acceptance_ref,
    },
    "accepted_warning_refs": [global_response["global_evaluation_report_ref"]],
    "downgrade_records": [{"kind": "debate_degraded", "backend": "template"}],
    "unresolved_decisions": [],
    "pending_decision_refs": [],
    "deferred_decisions": [],
    "completed_stage_refs": [f"state://runs/{run_id}/tasks.json"],
    "incomplete_stage_refs": [],
    "stop_request_ref": None,
    "run_stopped_event_ref": None,
    "preserved_artifact_refs": [f"state://runs/{run_id}/run.json", codex_worker_response["worker_output_report_ref"], claude_worker_response["worker_output_report_ref"]],
    "resume_checkpoint_refs": [],
    "worker_cancel_marker_refs": [],
    "test_execution_refs": [test_execution_ref],
    "review_verdict_refs": [claude_worker_response["worker_output_report_ref"]],
    "qa_verdict_refs": [],
    "worker_fallbacks": [],
    "knowledge_updates": {
        "auto_applied_refs": [],
        "proposal_refs": [],
        "forbidden_target_refs": [],
    },
    "system_improvement_proposals_ref": proposals_ref,
    "completion_gate": {
        "artifacts_schema_valid": True,
        "audit_closeout_recorded": True,
        "kanban_stage_tasks_done": True,
        "gateway_state_consistent": True,
        "completion_blockers": [],
    },
    "created_at": created_at,
}
proposals = {
    "schema_version": "orchestra.v1",
    "artifact_type": "system_improvement_proposals",
    "run_id": run_id,
    "source_refs": [closeout_ref],
    "proposals": [],
    "auto_applied_refs": [],
    "proposed_patch_refs": [],
    "approval_required": [],
    "decision_refs": [],
    "final_acceptance_ref": final_acceptance_ref,
    "downgrade_refs": [f"state://runs/{run_id}/debate-reports/direction_debate.json"],
    "worker_fallback_refs": [],
    "knowledge_update_refs": [],
}
closeout_response = post(
    f"/orchestra/runs/{run_id}/closeout",
    {
        "idempotency_key": f"real-worker-closeout-{demo_id}",
        "iteration_closeout_report": closeout,
        "system_improvement_proposals": proposals,
    },
    participant="wizard-as-kimi",
    stage="closeout",
    action="submit_closeout",
    what_happened="Wizard submitted closeout for the real-worker demo after Gateway recorded real CLI worker evidence and Kanban completion.",
    artifact_refs=[closeout_ref, proposals_ref, final_acceptance_ref, test_execution_ref, codex_worker_response["worker_output_report_ref"], claude_worker_response["worker_output_report_ref"]],
)
status = get(
    f"/orchestra/runs/{run_id}",
    participant="wizard-as-kimi",
    stage="verification",
    action="read_final_status",
    what_happened="Wizard read final run status to verify the real-worker demo completed.",
    input_data={"run_id": run_id},
    artifact_refs=[f"state://runs/{run_id}/run.json"],
)
events = get(
    f"/orchestra/runs/{run_id}/events?since_seq=0&limit=200",
    participant="wizard-as-kimi",
    stage="verification",
    action="read_events",
    what_happened="Wizard read event projection for the real-worker demo.",
    input_data={"run_id": run_id, "since_seq": 0, "limit": 200},
    artifact_refs=[f"state://runs/{run_id}/events.jsonl"],
)
if status.get("status") != "completed":
    raise SystemExit(f"real-worker demo run did not complete: {status}")

run_dir = pathlib.Path(state_dir) / project_id / "runs" / run_id
local_files = {
    "run_state": str(run_dir / "run.json"),
    "task_projection": str(run_dir / "tasks.json"),
    "events": str(run_dir / "events.jsonl"),
    "codex_result": str(codex_result_path),
    "codex_stdout": str(codex_stdout_path),
    "codex_stderr": str(codex_stderr_path),
    "claude_stdout": str(claude_stdout_path),
    "claude_stderr": str(claude_stderr_path),
    "low_risk_file": str(low_risk_path),
    "low_risk_file_status": str(git_status_path),
    "low_risk_file_diff": str(git_diff_path),
    "low_risk_file_content": str(file_content_path),
    "global_evaluation": str(run_dir / "global_evaluation_report.json"),
    "final_acceptance": str(run_dir / "final_acceptance.json"),
    "closeout": str(run_dir / "iteration_closeout_report.json"),
    "system_improvement_proposals": str(run_dir / "system_improvement_proposals.json"),
    "audit": str(pathlib.Path(audit_dir) / project_id / "audit.jsonl"),
    "real_worker_flow": str(pathlib.Path(flow_path)),
    "real_worker_log": str(log_file),
}
log_step(
    "wizard-as-kimi",
    "verification",
    "write_real_worker_summary",
    "Wizard wrote the real-worker demo summary with all CLI, Gateway, State, Audit, and changed-file evidence paths.",
    input_data={"run_id": run_id, "demo_id": demo_id},
    output_data={"local_files": local_files},
    artifact_refs=[
        f"state://runs/{run_id}/run.json",
        f"state://runs/{run_id}/tasks.json",
        f"state://runs/{run_id}/events.jsonl",
        codex_worker_response["worker_output_report_ref"],
        claude_worker_response["worker_output_report_ref"],
        closeout_ref,
        proposals_ref,
    ],
    local_files=list(local_files.values()),
)

with open(flow_path, "w", encoding="utf-8") as handle:
    json.dump(
        {
            "schema_version": "orchestra.v1",
            "artifact_type": "mvp_real_worker_flow",
            "run_id": run_id,
            "project_id": project_id,
            "project_dir": project_dir,
            "base_url": base_url,
            "log_ref": str(log_file),
            "participants": [
                {"name": "wizard-as-kimi", "role": "submits run, observes Gateway state, and records final acceptance"},
                {"name": "gateway-api", "role": "owns /orchestra/* workflow state, artifacts, events, idempotency, and gates"},
                {"name": "hermes-kanban", "role": "receives lifecycle create/complete operations from Gateway"},
                {"name": "codex-cli", "role": "real authenticated CLI implementer that modifies the approved low-risk file"},
                {"name": "claude-cli", "role": "real authenticated CLI reviewer that reviews the Codex change evidence"},
            ],
            "real_worker_change": {
                "demo_id": demo_id,
                "changed_file": low_risk_file.as_posix(),
                "codex_exit_code": codex_result["exit_code"],
                "claude_exit_code": claude_result["exit_code"],
                "codex_worker_output_ref": codex_worker_response["worker_output_report_ref"],
                "claude_worker_output_ref": claude_worker_response["worker_output_report_ref"],
            },
            "create_response": create,
            "closeout_response": closeout_response,
            "status": status,
            "events": events,
            "operation_count": len(operations),
            "operations": operations,
            "local_files": local_files,
            "created_at": created_at,
        },
        handle,
        indent=2,
        ensure_ascii=False,
    )
    handle.write("\n")

print(run_id)
PY
}

run_real_worker_demo_step() {
    local flow_path="$STATE_DIR/mvp-real-worker-flow.json"
    local log_path="$STATE_DIR/mvp-real-worker-log.jsonl"
    local run_id
    info "Running: mvp-real-worker-demo"
    if run_id="$(run_real_worker_demo "$flow_path" "$log_path")"; then
        ok "MVP real-worker demo completed: $run_id"
        ok "MVP real-worker flow: $flow_path"
        ok "MVP real-worker log: $log_path"
        record_step "mvp-real-worker-demo" "passed" "run_id:$run_id flow:$flow_path log:$log_path"
    else
        record_step "mvp-real-worker-demo" "failed" "flow:$flow_path log:$log_path"
        die "mvp-real-worker-demo failed"
    fi
}

if [ "$INTERACTIVE_CONFIRMATION" -eq 1 ] || [ "$BATCH_CONFIRMATION" -eq 1 ] || [ "$MOCK_CONFIRMATION" -eq 1 ]; then
    run_sprint3_correction
    exit 0
fi

if [ -z "$PROJECT_ID" ] && [ -n "${PROJECT_DIR:-}" ]; then
    run_sprint3_preview
    exit 0
fi

echo "========================================"
echo " Hermes Orchestra MVP Guided Wizard"
echo "========================================"

check_command git required
check_command python3 required
check_command make optional
check_command npm optional
check_command hermes optional
check_command tmux optional
check_command claude optional
check_command codex optional
check_env_file

if [ "$SKIP_SETUP" -eq 1 ]; then
    record_step "setup" "skipped" "--skip-setup"
elif [ -f "$PACKAGE_DIR/scripts/setup.sh" ] && ask_yes "Run scripts/setup.sh to install or refresh orch-* commands"; then
    run_step "setup" bash "$PACKAGE_DIR/scripts/setup.sh"
else
    record_step "setup" "skipped" "not requested or setup script unavailable"
fi

PROJECT_ID="$(prompt_value "Project ID" "$PROJECT_ID")" || die "project id is required"
PROJECT_DIR="$(prompt_value "Project directory" "$PROJECT_DIR")" || die "project dir is required"
orch_validate_project_id "$PROJECT_ID" || die "invalid project id"

if [ ! -d "$PROJECT_DIR" ]; then
    die "Project directory not found: $PROJECT_DIR"
fi
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    if [ "$INIT_GIT" -eq 1 ] || ask_yes "Project directory is not a git repository. Run git init"; then
        run_step "git-init" git -C "$PROJECT_DIR" init
    else
        die "Project directory must be a git repository"
    fi
else
    record_step "git-repository" "passed" "$PROJECT_DIR"
fi

orch_project_dirs "$PROJECT_ID"
if [ -z "$REPORT_PATH" ]; then
    REPORT_PATH="$STATE_DIR/mvp-acceptance-report.json"
fi

ORCH_INIT="$(resolve_helper orch-init)" || die "orch-init not found"
run_step "orch-init" "$ORCH_INIT" "$PROJECT_ID" "$PROJECT_DIR"

if [ "$SKIP_START" -eq 1 ]; then
    record_step "orch-start" "skipped" "--skip-start"
elif ask_yes "Start Claude/Codex tmux orchestration session with orch-start"; then
    ORCH_START="$(resolve_helper orch-start)" || die "orch-start not found"
    run_step "orch-start" "$ORCH_START" "$PROJECT_ID" "$PROJECT_DIR"
else
    record_step "orch-start" "skipped" "not requested"
fi

if [ "$SKIP_GATEWAY" -eq 1 ]; then
    record_step "orch-gateway" "skipped" "--skip-gateway"
elif ask_yes "Start Gateway API at http://$HOST:$PORT"; then
    ORCH_GATEWAY="$(resolve_helper orch-gateway)" || die "orch-gateway not found"
    mkdir -p "$STATE_DIR"
    GATEWAY_LOG="$STATE_DIR/gateway.log"
    GATEWAY_PID_FILE="$STATE_DIR/gateway.pid"
    if gateway_health_once; then
        if [ "$SKIP_TESTS" -eq 0 ] && { [ "$SKIP_DEMO" -eq 0 ] || [ "$REAL_WORKER_DEMO" -eq 1 ]; }; then
            record_step "orch-gateway" "failed" "existing:http://$HOST:$PORT"
            die "Gateway already running on http://$HOST:$PORT; full demo needs a fresh Gateway with ORCH_GATEWAY_RUN_TESTS=1. Use --port with a free port or stop the existing Gateway."
        fi
        ok "Gateway already healthy: http://$HOST:$PORT/health"
        GATEWAY_READY=1
        record_step "orch-gateway" "passed" "existing:http://$HOST:$PORT"
    else
        if [ "$SKIP_TESTS" -eq 0 ] && { [ "$SKIP_DEMO" -eq 0 ] || [ "$REAL_WORKER_DEMO" -eq 1 ]; }; then
            GATEWAY_TEST_COMMAND="${ORCH_GATEWAY_TEST_COMMAND:-make -C $PACKAGE_DIR test}"
            if [ "$REAL_WORKER_DEMO" -eq 1 ]; then
                GATEWAY_TEST_COMMAND="${ORCH_GATEWAY_TEST_COMMAND:-make -C $PACKAGE_DIR test-risk}"
            fi
            ORCH_GATEWAY_RUN_TESTS=1 ORCH_GATEWAY_TEST_COMMAND="$GATEWAY_TEST_COMMAND" "$ORCH_GATEWAY" --project-id "$PROJECT_ID" --host "$HOST" --port "$PORT" >"$GATEWAY_LOG" 2>&1 &
        else
            "$ORCH_GATEWAY" --project-id "$PROJECT_ID" --host "$HOST" --port "$PORT" >"$GATEWAY_LOG" 2>&1 &
        fi
        GATEWAY_PID="$!"
        printf '%s\n' "$GATEWAY_PID" > "$GATEWAY_PID_FILE"
        if wait_gateway_health "$GATEWAY_LOG"; then
            ok "Gateway healthy: http://$HOST:$PORT/health"
            GATEWAY_READY=1
            record_step "orch-gateway" "passed" "pid:$GATEWAY_PID"
        else
            record_step "orch-gateway" "failed" "$GATEWAY_LOG"
            die "Gateway failed to become healthy"
        fi
    fi
else
    record_step "orch-gateway" "skipped" "not requested"
fi

if [ "$SKIP_TESTS" -eq 1 ]; then
    record_step "acceptance-tests" "skipped" "--skip-tests"
elif [ -f "$PACKAGE_DIR/Makefile" ]; then
    run_step "make-test" make -C "$PACKAGE_DIR" test
    if [ -f "$PACKAGE_DIR/package.json" ] && command -v npm >/dev/null 2>&1; then
        run_step "npm-test" npm --prefix "$PACKAGE_DIR" --silent test
    else
        record_step "npm-test" "skipped" "npm or package.json unavailable"
    fi
    if [ "$STRICT_UPSTREAM" -eq 1 ]; then
        run_step "upstream-status-strict" make -C "$PACKAGE_DIR" upstream-status-strict
    else
        run_step "upstream-status" make -C "$PACKAGE_DIR" upstream-status
    fi
else
    ORCH_VERIFY="$(resolve_helper orch-verify)" || die "orch-verify not found"
    run_step "orch-verify" "$ORCH_VERIFY"
fi

if [ "$SKIP_DEMO" -eq 1 ]; then
    record_step "mvp-demo-run" "skipped" "--skip-demo"
elif [ "$SKIP_TESTS" -eq 1 ]; then
    record_step "mvp-demo-run" "skipped" "--skip-tests"
elif [ "$SKIP_GATEWAY" -eq 1 ]; then
    record_step "mvp-demo-run" "skipped" "--skip-gateway"
elif [ "$GATEWAY_READY" -eq 1 ]; then
    run_mvp_demo_step
else
    record_step "mvp-demo-run" "skipped" "gateway not started"
fi

if [ "$REAL_WORKER_DEMO" -eq 0 ]; then
    record_step "mvp-real-worker-demo" "skipped" "not requested"
elif [ "$SKIP_TESTS" -eq 1 ]; then
    record_step "mvp-real-worker-demo" "failed" "--skip-tests"
    die "mvp-real-worker-demo requires acceptance tests because closeout needs executed test evidence"
elif [ "$SKIP_GATEWAY" -eq 1 ]; then
    record_step "mvp-real-worker-demo" "failed" "--skip-gateway"
    die "mvp-real-worker-demo requires Gateway"
elif [ "$GATEWAY_READY" -eq 1 ]; then
    run_real_worker_demo_step
else
    record_step "mvp-real-worker-demo" "failed" "gateway not started"
    die "mvp-real-worker-demo requires a running Gateway"
fi

write_report "passed"

echo ""
echo "MVP guided acceptance complete"
echo "Project: $PROJECT_ID"
echo "Project dir: $PROJECT_DIR"
echo "Report: $REPORT_PATH"
if [ "$SKIP_GATEWAY" -eq 0 ] && [ -f "${GATEWAY_PID_FILE:-}" ]; then
    echo "Gateway: http://$HOST:$PORT (pid $(cat "$GATEWAY_PID_FILE"))"
elif [ "$GATEWAY_READY" -eq 1 ]; then
    echo "Gateway: http://$HOST:$PORT (existing)"
fi
