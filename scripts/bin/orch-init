#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PACKAGE_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
ORCHESTRA_HOME="${ORCHESTRA_HOME:-$HOME/.hermes-orchestra}"

if [ -f "$ORCHESTRA_HOME/lib/orch-common.sh" ]; then
    # shellcheck source=/dev/null
    source "$ORCHESTRA_HOME/lib/orch-common.sh"
else
    # shellcheck source=/dev/null
    source "$SCRIPT_DIR/../lib/orch-common.sh"
fi

if [ "$#" -ne 2 ]; then
    echo "Usage: orch-init <project-id> <project-dir>" >&2
    exit 1
fi

PROJECT_ID="$1"
PROJECT_DIR_INPUT="$2"

orch_validate_project_id "$PROJECT_ID"
orch_require_command git
orch_require_command python3

if [ ! -d "$PROJECT_DIR_INPUT" ]; then
    echo "Project directory not found: $PROJECT_DIR_INPUT" >&2
    exit 1
fi

PROJECT_DIR="$(cd "$PROJECT_DIR_INPUT" && pwd)"

if ! git -C "$PROJECT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Project directory must already be a Git repository: $PROJECT_DIR" >&2
    exit 1
fi

orch_project_dirs "$PROJECT_ID"
WORKSPACE_ROOT="$(orch_project_workspace_root "$PROJECT_DIR" "$PROJECT_ID")"
OVERRIDE_DIR="$(orch_project_override_dir "$PROJECT_DIR")"
BOARD_SLUG="$(orch_project_board_slug "$PROJECT_ID")"
MEMORY_NAMESPACE="$(orch_project_memory_namespace "$PROJECT_ID")"

mkdir -p "$RUNTIME_DIR" "$STATE_DIR" "$AUDIT_DIR/archive" "$AUDIT_DIR/pending" "$CACHE_DIR" "$WORKSPACE_ROOT" "$OVERRIDE_DIR"
mkdir -p "$PROJECT_DIR/.workflow/knowledge"

SETTINGS_SRC="$ORCHESTRA_HOME/claude-config-template/.claude/settings.json"
if [ ! -f "$SETTINGS_SRC" ]; then
    SETTINGS_SRC="$PACKAGE_DIR/claude-config/settings.json"
fi
if [ ! -f "$PROJECT_DIR/.claude/settings.json" ]; then
    if [ ! -f "$SETTINGS_SRC" ]; then
        echo "Claude settings template missing: $SETTINGS_SRC" >&2
        exit 1
    fi
    mkdir -p "$PROJECT_DIR/.claude"
    cp "$SETTINGS_SRC" "$PROJECT_DIR/.claude/settings.json"
    echo "Claude settings copied: $PROJECT_DIR/.claude/settings.json"
else
    echo "Claude settings already exist: $PROJECT_DIR/.claude/settings.json"
fi

{
    printf 'PROJECT_ID=%q\n' "$PROJECT_ID"
    printf 'PROJECT_DIR=%q\n' "$PROJECT_DIR"
    printf 'RUNTIME_DIR=%q\n' "$RUNTIME_DIR"
    printf 'STATE_DIR=%q\n' "$STATE_DIR"
    printf 'AUDIT_DIR=%q\n' "$AUDIT_DIR"
    printf 'CACHE_DIR=%q\n' "$CACHE_DIR"
    printf 'CLAUDE_SESSION=%q\n' "$CLAUDE_SESSION"
    printf 'CODEX_SESSION=%q\n' "$CODEX_SESSION"
    printf 'WORKSPACE_ROOT=%q\n' "$WORKSPACE_ROOT"
    printf 'OVERRIDE_DIR=%q\n' "$OVERRIDE_DIR"
    printf 'BOARD_SLUG=%q\n' "$BOARD_SLUG"
    printf 'MEMORY_NAMESPACE=%q\n' "$MEMORY_NAMESPACE"
} > "$STATE_DIR/project.env"

python3 - "$STATE_DIR/paths.json" "$PROJECT_ID" "$PROJECT_DIR" "$RUNTIME_DIR" "$STATE_DIR" "$AUDIT_DIR" "$CACHE_DIR" "$WORKSPACE_ROOT" "$OVERRIDE_DIR" "$BOARD_SLUG" "$MEMORY_NAMESPACE" <<'PY'
import json, sys
path, project_id, project_dir, runtime_dir, state_dir, audit_dir, cache_dir, workspace_root, override_dir, board_slug, memory_namespace = sys.argv[1:]
with open(path, "w", encoding="utf-8") as handle:
    json.dump({
        "project_id": project_id,
        "project_dir": project_dir,
        "runtime_dir": runtime_dir,
        "state_dir": state_dir,
        "audit_dir": audit_dir,
        "cache_dir": cache_dir,
        "workspace_root": workspace_root,
        "override_dir": override_dir,
        "board_slug": board_slug,
        "memory_namespace": memory_namespace,
    }, handle, indent=2)
    handle.write("\n")
PY

mkdir -p "$STATE_ROOT"
python3 - "$STATE_ROOT/projects.json" "$PROJECT_ID" "$PROJECT_DIR" "$RUNTIME_DIR" "$STATE_DIR" "$AUDIT_DIR" "$CACHE_DIR" "$WORKSPACE_ROOT" "$OVERRIDE_DIR" "$BOARD_SLUG" "$MEMORY_NAMESPACE" "$(orch_now)" <<'PY'
import json, os, sys
path, project_id, project_dir, runtime_dir, state_dir, audit_dir, cache_dir, workspace_root, override_dir, board_slug, memory_namespace, updated_at = sys.argv[1:]
try:
    with open(path, encoding="utf-8") as handle:
        projects = json.load(handle)
    if not isinstance(projects, list):
        projects = []
except Exception:
    projects = []

entry = {
    "project_id": project_id,
    "project_dir": project_dir,
    "runtime_dir": runtime_dir,
    "state_dir": state_dir,
    "audit_dir": audit_dir,
    "cache_dir": cache_dir,
    "workspace_root": workspace_root,
    "override_dir": override_dir,
    "board_slug": board_slug,
    "memory_namespace": memory_namespace,
    "updated_at": updated_at,
}
projects = [project for project in projects if project.get("project_id") != project_id]
projects.append(entry)
projects.sort(key=lambda project: project["project_id"])

tmp = f"{path}.tmp"
with open(tmp, "w", encoding="utf-8") as handle:
    json.dump(projects, handle, indent=2)
    handle.write("\n")
os.replace(tmp, path)
PY

python3 - "$STATE_DIR/current-task.json" "$PROJECT_ID" <<'PY'
import json, sys
path, project_id = sys.argv[1:]
with open(path, "w", encoding="utf-8") as handle:
    json.dump({"project_id": project_id, "state": "idle", "task_id": None}, handle, indent=2)
    handle.write("\n")
PY

python3 - "$PROJECT_DIR" "$PROJECT_ID" "$PACKAGE_DIR" "$(orch_now)" <<'PY'
import hashlib
import json
import os
import sys
from pathlib import Path
from typing import Any

project_dir, project_id, package_dir, generated_at = sys.argv[1:]
project = Path(project_dir)
package = Path(package_dir)
knowledge = project / ".workflow" / "knowledge"
knowledge.mkdir(parents=True, exist_ok=True)

def read_json(path):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return None

def file_digest(path):
    try:
        data = path.read_bytes()
    except OSError:
        return None
    return hashlib.sha256(data).hexdigest()

package_json = read_json(project / "package.json") or read_json(package / "package.json") or {}
codemap = read_json(package / ".mycodemap" / "codemap.json") or {}

docs = {}
for relative in ("README.md", "Makefile", "AGENTS.md", "hermes/SOUL.md"):
    digest = file_digest(project / relative) or file_digest(package / relative)
    if digest:
        docs[relative] = {"sha256": digest}

payloads = {
    "project-summary.json": {
        "schema_version": "orchestra.v1",
        "artifact_type": "workflow_knowledge",
        "knowledge_type": "project_summary",
        "project_id": project_id,
        "summary": package_json.get("description") or "Hermes Orchestra project",
        "source_refs": sorted(docs),
        "generated_at": generated_at,
    },
    "tech-stack.json": {
        "schema_version": "orchestra.v1",
        "artifact_type": "workflow_knowledge",
        "knowledge_type": "tech_stack",
        "project_id": project_id,
        "runtime": "python-standard-library-http-server",
        "package_type": package_json.get("type"),
        "test_entrypoint": "make test",
        "generated_at": generated_at,
    },
    "api-surface.json": {
        "schema_version": "orchestra.v1",
        "artifact_type": "workflow_knowledge",
        "knowledge_type": "api_surface",
        "project_id": project_id,
        "routes": [
            "GET /health",
            "GET /orchestra/capabilities",
            "POST /orchestra/runs",
            "GET /orchestra/runs/{run_id}",
            "GET /orchestra/runs/{run_id}/events",
            "GET /orchestra/runs/{run_id}/tasks",
            "POST /orchestra/runs/{run_id}/stop",
            "POST /orchestra/decisions/{decision_id}",
        ],
        "generated_at": generated_at,
    },
    "module-map.json": {
        "schema_version": "orchestra.v1",
        "artifact_type": "workflow_knowledge",
        "knowledge_type": "module_map",
        "project_id": project_id,
        "modules": codemap.get("modules", []),
        "key_paths": ["scripts/", "hermes/", "specs/", "docs/", "config/"],
        "generated_at": generated_at,
    },
    "coding-rules.json": {
        "schema_version": "orchestra.v1",
        "artifact_type": "workflow_knowledge",
        "knowledge_type": "coding_rules",
        "project_id": project_id,
        "rules": ["Use scoped artifact refs", "Do not auto-edit root rule files", "Keep Gateway local-only by default"],
        "source_digests": docs,
        "generated_at": generated_at,
    },
    "test-strategy.json": {
        "schema_version": "orchestra.v1",
        "artifact_type": "workflow_knowledge",
        "knowledge_type": "test_strategy",
        "project_id": project_id,
        "commands": ["make test", "bash scripts/tests/run-all.sh"],
        "generated_at": generated_at,
    },
    "risk-notes.json": {
        "schema_version": "orchestra.v1",
        "artifact_type": "workflow_knowledge",
        "knowledge_type": "risk_notes",
        "project_id": project_id,
        "notes": ["Human approval required for root rules, CI/CD, secrets, permissions, and publish/deploy actions"],
        "generated_at": generated_at,
    },
}

manifest_inputs = {}
for name, payload in payloads.items():
    target = knowledge / name
    target.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    manifest_inputs[name] = {"sha256": file_digest(target), "generated_at": generated_at}

(knowledge / "update-manifest.json").write_text(
    json.dumps(
        {
            "schema_version": "orchestra.v1",
            "artifact_type": "workflow_knowledge_update_manifest",
            "project_id": project_id,
            "files": manifest_inputs,
            "source_digests": docs,
            "generated_at": generated_at,
        },
        indent=2,
        ensure_ascii=False,
    )
    + "\n",
    encoding="utf-8",
)

# --- Sprint 1: Project Discovery Pipeline ---
import time

discovery_start = time.monotonic()
MAX_DISCOVERY_SECONDS = 300


def detect_tech_stack(project: Path) -> dict:
    stack = {"languages": [], "frameworks": [], "package_managers": [], "versions": {}}
    files_checked = {
        "package.json": ("javascript", "npm/yarn"),
        "pyproject.toml": ("python", "poetry/pip"),
        "requirements.txt": ("python", "pip"),
        "setup.py": ("python", "setuptools"),
        "Cargo.toml": ("rust", "cargo"),
        "go.mod": ("go", "go-modules"),
        "Gemfile": ("ruby", "bundler"),
        "pom.xml": ("java", "maven"),
        "build.gradle": ("java", "gradle"),
        "composer.json": ("php", "composer"),
    }
    for fname, (lang, pm) in files_checked.items():
        if (project / fname).exists():
            if lang not in stack["languages"]:
                stack["languages"].append(lang)
            if pm not in stack["package_managers"]:
                stack["package_managers"].append(pm)
    # Framework detection across package managers
    all_deps: dict[str, str] = {}
    # Node.js
    pj = read_json(project / "package.json") or {}
    all_deps.update(pj.get("dependencies", {}))
    all_deps.update(pj.get("devDependencies", {}))
    # Python (pyproject.toml)
    ppt: dict[str, Any] = {}
    if (project / "pyproject.toml").exists():
        try:
            import tomllib
            with open(project / "pyproject.toml", "rb") as fh:
                ppt = tomllib.load(fh)
        except Exception:
            pass
    if ppt:
        def _norm_pkg(name: str) -> str:
            return name.split("[")[0].split("==")[0].split(">=")[0].split("<")[0].strip().lower()
        for dep in ppt.get("project", {}).get("dependencies", []):
            if isinstance(dep, str):
                all_deps[_norm_pkg(dep)] = ""
        for dep in ppt.get("project", {}).get("optional-dependencies", {}):
            if isinstance(dep, str):
                all_deps[_norm_pkg(dep)] = ""
        for dep in ppt.get("tool", {}).get("poetry", {}).get("dependencies", {}):
            if isinstance(dep, str):
                all_deps[_norm_pkg(dep)] = ""
    # Python (requirements.txt)
    req_path = project / "requirements.txt"
    if req_path.exists():
        for line in req_path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if line and not line.startswith("#"):
                pkg = line.split("==")[0].split(">=")[0].split("<")[0].strip()
                if pkg:
                    all_deps[pkg] = ""
    framework_map = {"next": "Next.js", "react": "React", "vue": "Vue", "express": "Express", "fastapi": "FastAPI", "django": "Django", "flask": "Flask", "rails": "Ruby on Rails", "spring-boot": "Spring Boot"}
    for dep_name, fw_name in framework_map.items():
        if dep_name in all_deps:
            stack["frameworks"].append(fw_name)
    # Version extraction
    if pj.get("version"):
        stack["versions"]["project"] = pj["version"]
    if ppt.get("project", {}).get("version"):
        stack["versions"]["project"] = ppt["project"]["version"]
    if (project / "Dockerfile").exists() or any(project.glob("**/Dockerfile")):
        stack["container_ready"] = True
    return stack


def detect_test_commands(project: Path) -> list[str]:
    candidates = []
    if (project / "Makefile").exists():
        text = (project / "Makefile").read_text(encoding="utf-8")
        for line in text.splitlines():
            if line.strip().startswith("test:"):
                candidates.append("make test")
                break
    if (project / "package.json").exists():
        pj = read_json(project / "package.json") or {}
        scripts = pj.get("scripts", {})
        if "test" in scripts:
            candidates.append("npm test")
    if (project / "pyproject.toml").exists():
        candidates.append("pytest")
    if not candidates:
        candidates.append("make test")
    return candidates


def detect_deploy_target(project: Path) -> str:
    if (project / "vercel.json").exists():
        return "static/vercel"
    if (project / "netlify.toml").exists():
        return "static/netlify"
    if (project / "fly.toml").exists():
        return "container/fly"
    if (project / "Dockerfile").exists():
        return "container/docker"
    if (project / "serverless.yml").exists() or (project / "serverless.yaml").exists():
        return "faas/serverless"
    if (project / "package.json").exists():
        return "static/nodejs"
    if (project / "pyproject.toml").exists() or (project / "requirements.txt").exists():
        return "container/python"
    return "unknown"


def detect_risk_flags(project: Path) -> list[str]:
    flags = []
    protected_files = [".env", ".env.local", ".env.production", "secrets.json", "id_rsa"]
    for pf in protected_files:
        if (project / pf).exists():
            flags.append(f"protected_target:{pf}")
    git_config = project / ".git" / "config"
    if git_config.exists():
        text = git_config.read_text(encoding="utf-8")
        if "url = git@github.com" in text:
            flags.append("protected_target:ssh_git_remote")
    return flags


def run_discovery(project: Path) -> dict:
    stack = detect_tech_stack(project)
    test_cmds = detect_test_commands(project)
    deploy = detect_deploy_target(project)
    risks = detect_risk_flags(project)
    elapsed = time.monotonic() - discovery_start
    status = "complete"
    if elapsed > MAX_DISCOVERY_SECONDS:
        status = "partial"
    # Empty directory: no build files detected
    if not stack["languages"] and deploy == "unknown" and not risks:
        status = "unknown"
    return {
        "tech_stack": stack,
        "test_command": test_cmds[0] if test_cmds else "unknown",
        "test_commands": test_cmds,
        "deploy_target": deploy,
        "risk_flags": risks,
        "status": status,
        "discovery_seconds": round(elapsed, 2),
    }


discovery_report = run_discovery(project)

# Write project-profile.yaml (merge with existing to preserve user-defined fields)
hermes_dir = project / ".hermes"
hermes_dir.mkdir(parents=True, exist_ok=True)
profile_yaml = hermes_dir / "project-profile.yaml"

existing_profile: dict[str, Any] = {}
if profile_yaml.exists():
    for line in profile_yaml.read_text(encoding="utf-8").splitlines():
        if ":" in line and not line.strip().startswith("#"):
            key, val = line.split(":", 1)
            key = key.strip()
            val = val.strip()
            if val.startswith("[") and val.endswith("]"):
                items = [v.strip() for v in val[1:-1].split(",") if v.strip()]
                existing_profile[key] = items
            else:
                existing_profile[key] = val

with open(profile_yaml, "w", encoding="utf-8") as f:
    f.write(f"name: {existing_profile.get('name', project_id)}\n")
    f.write(f"project_id: {project_id}\n")
    f.write(f"project_dir: {str(project)}\n")
    f.write("profile_version: 2\n")
    f.write("source_of_truth: yaml\n")
    ts_list = ", ".join(discovery_report["tech_stack"]["languages"])
    f.write(f"tech_stack: [{ts_list}]\n")
    f.write(f"test_command: {discovery_report['test_command']}\n")
    f.write(f"deploy_target: {discovery_report['deploy_target']}\n")
    rf_list = ", ".join(discovery_report["risk_flags"])
    f.write(f"risk_flags: [{rf_list}]\n")
    f.write(f"discovery_status: {discovery_report['status']}\n")

# Write detection report draft
detection_report_path = knowledge / "detection-report.json"
detection_report_path.write_text(
    json.dumps(
        {
            "schema_version": "orchestra.v1",
            "artifact_type": "project_detection_report",
            "project_id": project_id,
            "detection_report": discovery_report,
            "generated_at": generated_at,
        },
        indent=2,
        ensure_ascii=False,
    )
    + "\n",
    encoding="utf-8",
)
PY

SYNC_HELPER="$ORCHESTRA_HOME/bin/orch-profile-sync"
if [ ! -x "$SYNC_HELPER" ]; then
    SYNC_HELPER="$SCRIPT_DIR/orch-profile-sync"
fi
if [ -x "$SYNC_HELPER" ]; then
    "$SYNC_HELPER" "$PROJECT_ID" "$PROJECT_DIR" >/dev/null
fi

orch_append_audit "project_init" "$PROJECT_ID" "L1" "RECORDED" "" "Project initialized at $PROJECT_DIR" "" "" "" "" "orch-init" ""

echo "Project initialized: $PROJECT_ID"
echo "Runtime: $RUNTIME_DIR"
echo "State:   $STATE_DIR"
echo "Audit:   $AUDIT_DIR"
echo "Cache:   $CACHE_DIR"
echo "Workspace: $WORKSPACE_ROOT"
echo "Overrides: $OVERRIDE_DIR"
echo "Board: $BOARD_SLUG"
echo "Memory: $MEMORY_NAMESPACE"
